# Generators participate in the iteration protocol used by `for`.

(fn counter* [n]
  (var i 0)
  (while (i < n)
    (yield i)
    (i += 1)))

(var sum 0)
(for i in (counter* 4)
  (sum += i))
(assert (sum == 6))

(fn pairs* []
  (yield [0 2])
  (yield [1 3]))

(var pair_sum 0)
(for k v in (pairs*)
  (pair_sum += k)
  (pair_sum += v))
(assert (pair_sum == 6))

(println "generator for iteration passed!")

# Expected: generator for iteration passed!
