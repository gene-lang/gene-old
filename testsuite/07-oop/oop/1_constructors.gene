# Expected: point=10,20
# Expected: keyword_sum=7

(class Point
  ^fields {^x Any ^y Any}
  (ctor [x y]
    (/x = x)
    (/y = y)
  )
  (method coords []
    ((/x .to_s) ++ "," ++ (/y .to_s))
  )
)

(var p (new Point 10 20))
(println "point=" (p .coords))

(class KeywordPoint
  ^fields {^sum Any}
  (ctor [^x ^y]
    (/sum = (+ x y))
  )
  (method sum []
    /sum
  )
)

(var kp (new KeywordPoint ^x 3 ^y 4))
(println "keyword_sum=" (kp .sum))
