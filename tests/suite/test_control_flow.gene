# test_control_flow.gene — if/elif/else, loop, for-in, break/continue

(import * as T "./testkit")
(var t (new T/Suite "test_control_flow.gene"))

# If/else
(t .section "If/Else")
(t .assert_eq (if true 1 else 2) 1 "if true => 1")
(t .assert_eq (if false 1 else 2) 2 "if false => 2")
(t .assert_eq (if true 42) 42 "if true => 42")

# If as expression
(var x (if true "yes" else "no"))
(t .assert_eq x "yes" "if as expression")

# Elif
(t .section "Elif")
(var val 5)
(var result
  (if (val > 10) "big"
   elif (val > 3) "medium"
   else "small"))
(t .assert_eq result "medium" "elif chain: medium")

(val = 15)
(var result2
  (if (val > 10) "big"
   elif (val > 3) "medium"
   else "small"))
(t .assert_eq result2 "big" "elif chain: big")

(val = 1)
(var result3
  (if (val > 10) "big"
   elif (val > 3) "medium"
   else "small"))
(t .assert_eq result3 "small" "elif chain: small")

# Nested if
(t .section "Nested If")
(t .assert_eq
  (if true
    (if false 1 else 2)
  else 3)
  2 "nested if")

# Loop with break
(t .section "Loop/Break")
(var count 0)
(loop
  (count += 1)
  (if (count >= 5) (break)))
(t .assert_eq count 5 "loop breaks at 5")

# Loop with continue
(t .section "Loop/Continue")
(var sum 0)
(var i 0)
(loop
  (i += 1)
  (if (i > 10) (break))
  (if ((i % 2) == 0) (continue))
  (sum += i))
(t .assert_eq sum 25 "sum of odd 1-10 = 25")

# For-in array
(t .section "For-in")
(var total 0)
(for x in [10 20 30]
  (total += x))
(t .assert_eq total 60 "for-in sum = 60")

# For-in collecting
(var items [])
(for x in [1 2 3 4 5]
  (if (x > 3)
    (do)))  # just iterate
(var counted 0)
(for x in [1 2 3 4 5]
  (counted += 1))
(t .assert_eq counted 5 "for-in counted 5 items")

# For-in nested
(t .section "Nested For-in")
(var product_sum 0)
(for a in [1 2 3]
  (for b in [10 20]
    (product_sum += (a * b))))
(t .assert_eq product_sum 180 "nested for sum = 180")

# Loop counter pattern
(t .section "Loop Counter")
(var n 0)
(var factorial 1)
(loop
  (n += 1)
  (factorial *= n)
  (if (n >= 5) (break)))
(t .assert_eq factorial 120 "loop factorial(5) = 120")

# While loop
(t .section "While")
(var wx 4)
(while (wx > 0)
  (wx -= 1))
(t .assert_eq wx 0 "while loop decrements to zero")

# Repeat loop
(t .section "Repeat")
(var rx 0)
(repeat 4
  (rx += 3))
(t .assert_eq rx 12 "repeat runs body fixed times")

(var rsum 0)
(var rseen 0)
(repeat 10
  (rseen += 1)
  (if (rseen > 6) (break))
  (if ((rseen % 2) == 0) (continue))
  (rsum += rseen))
(t .assert_eq rsum 9 "repeat honors continue and break")
(t .assert_eq rseen 7 "repeat break exits early")

# Threads
(t .section "Threads")
(cap_grant "cap.thread.spawn")
(fn worker [] 42)
(var th (thread/spawn worker))
(t .assert_eq (thread/join th) 42 "thread spawn/join returns result")

# Case/when/else
(t .section "Case")
(var cval 2)
(var case_res
  (case cval
    when 1 "one"
    when 2 "two"
    else "other"))
(t .assert_eq case_res "two" "case chooses matching branch")

(t .done)
