# test_exceptions.gene — try/catch, throw

(import * as T "./testkit")
(var t (new T/Suite "test_exceptions.gene"))

# Basic try-catch
(t .section "Try/Catch")
(var result
  (try
    (throw "oops")
  catch e
    42))
(t .assert_eq result 42 "catch returns 42")

# Try without error
(var result2
  (try
    99
  catch e
    0))
(t .assert_eq result2 99 "try without error returns 99")

# Catch captures error
(var caught_err nil)
(try
  (throw "my error")
catch e
  (caught_err = e))
# caught_err should be a string-like error value

# Division by zero
(t .section "Division by Zero")
(var div_result
  (try
    (/ 1 0)
  catch e
    -1))
(t .assert_eq div_result -1 "div by zero caught")

# Nested try-catch
(t .section "Nested Try/Catch")
(var nested_result
  (try
    (try
      (throw "inner")
    catch e
      "caught inner")
  catch e
    "caught outer"))
(t .assert_eq nested_result "caught inner" "inner catch handles")

# Try-catch in function
(t .section "Exception in Function")
(fn safe_div [a b]
  (try
    (/ a b)
  catch e
    0))
(t .assert_eq (safe_div 10 2) 5.0 "safe_div(10, 2) = 5")
(t .assert_eq (safe_div 1 0) 0 "safe_div(1, 0) = 0")

# Throw from function
(fn fail_fn []
  (throw "function error"))

(var fn_err
  (try
    (fail_fn)
  catch e
    "caught from fn"))
(t .assert_eq fn_err "caught from fn" "catch error from function")

# Error does not propagate when caught
(var propagated false)
(try
  (try
    (throw "error1")
  catch e
    "handled")
  (propagated = true)
catch e
  (propagated = false))
# After inner catch, execution continues
(t .assert_true propagated "error handled, execution continues")

(t .done)
