# test_async.gene — async/await

(import * as T "./testkit")
(var t (new T/Suite "test_async.gene"))

# Basic async/await
(t .section "Basic Async")
(var r1 (await (async 42)))
(t .assert_eq r1 42 "await async 42")

(var r2 (await (async nil)))
(t .assert_eq r2 nil "await async nil")

(var r3 (await (async (+ 1 2))))
(t .assert_eq r3 3 "await async (+ 1 2)")

# Async with variable
(t .section "Async with Variables")
(var future (async (* 6 7)))
(var result (await future))
(t .assert_eq result 42 "await stored future")

# Multiple async
(t .section "Multiple Async")
(var f1 (async 10))
(var f2 (async 20))
(var total ((await f1) + (await f2)))
(t .assert_eq total 30 "sum of two awaited futures")

# Async preserves value types
(t .section "Async Value Types")
(t .assert_eq (await (async "hello")) "hello" "async string")
(t .assert_eq (await (async true)) true "async bool")
(var async_arr (await (async [1 2 3])))
(t .assert_eq (len async_arr) 3 "async array")

(t .done)
