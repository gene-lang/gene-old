# test_classes.gene — class, ctor, method, inheritance, super

(import * as T "./testkit")
(var t (new T/Suite "test_classes.gene"))

# Basic class with constructor
(t .section "Basic Class")
(class Point
  (ctor [x y]
    (/x = x)
    (/y = y))
  (method get_x [] /x)
  (method get_y [] /y)
  (method sum [] (/x + /y)))

(var p (new Point 3 4))
(t .assert_eq p/x 3 "Point p/x = 3")
(t .assert_eq p/y 4 "Point p/y = 4")
(t .assert_eq (p .get_x) 3 "Point get_x() = 3")
(t .assert_eq (p .get_y) 4 "Point get_y() = 4")
(t .assert_eq (p .sum) 7 "Point sum() = 7")

# Method with parameters
(t .section "Methods with Parameters")
(class Calculator
  (ctor [base]
    (/base = base))
  (method add [n]
    (/base + n))
  (method multiply [n]
    (/base * n)))

(var calc (new Calculator 10))
(t .assert_eq (calc .add 5) 15 "calc.add(5) = 15")
(t .assert_eq (calc .multiply 3) 30 "calc.multiply(3) = 30")

# Field mutation
(t .section "Field Mutation")
(class Counter
  (ctor []
    (/count = 0))
  (method inc []
    (/count = (/count + 1))
    /count)
  (method value [] /count))

(var c (new Counter))
(t .assert_eq (c .value) 0 "counter starts at 0")
(c .inc)
(c .inc)
(c .inc)
(t .assert_eq (c .value) 3 "counter after 3 increments = 3")

# Inheritance
(t .section "Inheritance")
(class Animal
  (ctor [name]
    (/name = name))
  (method speak []
    "..."))

(class Dog < Animal
  (ctor [name]
    (/name = name))
  (method speak []
    "Woof!"))

(class Cat < Animal
  (ctor [name]
    (/name = name))
  (method speak []
    "Meow!"))

(var d (new Dog "Rex"))
(var ca (new Cat "Whiskers"))
(t .assert_eq d/name "Rex" "Dog has name = Rex")
(t .assert_eq (d .speak) "Woof!" "Dog.speak() = Woof!")
(t .assert_eq (ca .speak) "Meow!" "Cat.speak() = Meow!")

# Multiple instances
(t .section "Multiple Instances")
(var p1 (new Point 1 2))
(var p2 (new Point 10 20))
(t .assert_eq p1/x 1 "p1/x = 1")
(t .assert_eq p2/x 10 "p2/x = 10")
(t .assert_eq (p1 .sum) 3 "p1.sum() = 3")
(t .assert_eq (p2 .sum) 30 "p2.sum() = 30")

(t .done)
