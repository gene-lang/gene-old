# test_modules_aop.gene — file imports, namespaces, aspect bundles

(import * as T "./testkit")
(var t (new T/Suite "test_modules_aop.gene"))

# File-based imports
(t .section "Import")
(import * as Utils "./module_utils")
(import * as Utils2 "./module_utils")
(t .assert_eq Utils/answer 42 "imported namespace value")
(t .assert_eq (Utils/inc 9) 10 "imported namespace function")
(t .assert_eq Utils2/answer 42 "cached second import value")

# Namespace block
(t .section "Namespace")
(ns Config
  (var debug true)
  (var version "1.0"))
(t .assert_eq Config/debug true "namespace value bool")
(t .assert_eq Config/version "1.0" "namespace value string")

# Aspect bundle callable
(t .section "Aspect Bundle")
(aspect X [cls m1]
  (before m1 [a...] nil))
(t .assert_eq (X Utils `inc) nil "aspect bundle call returns nil")

(t .done)
