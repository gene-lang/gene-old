#!/usr/bin/env gene run

(import TMP_PATH from "config")
(import send_document_candidate_paths select_send_document_path from "documents")
(import init_tools invoke_tool from "tools")

(var tmp_file #"#{TMP_PATH}/send_document_test.md")
(gene/io/write tmp_file "# test")

(var candidates (send_document_candidate_paths "send_document_test.md"))
(var artifact_candidate candidates/0)
(var tmp_candidate candidates/1)
(assert ((candidates/.size == 2) == true))
(assert ((artifact_candidate .end_with? "/assets/generated/send_document_test.md") == true))
(assert ((tmp_candidate .start_with? TMP_PATH) == true))
(assert ((tmp_candidate .end_with? "/send_document_test.md") == true))
(assert ((select_send_document_path "send_document_test.md") == tmp_candidate))

(init_tools)

(var result (invoke_tool "run-1" "ws" "u1" "C1" "T1" "ws:C1:T1" "send_document" {}))

(assert ((result/ok == false) == true))
(assert ((result/result/ok == false) == true))
(assert (((result/result/error || "") .include? "Missing path") == true))

(var missing_result (invoke_tool "run-2" "ws" "u1" "C1" "T1" "ws:C1:T1" "send_document" {^path "missing.png"}))
(assert ((missing_result/ok == false) == true))
(assert (((missing_result/error || "") .include? "Managed file not found") == true))

(println "ok")
