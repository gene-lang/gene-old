#!/usr/bin/env gene run

(import GENECLAW_HOME HOME_STATE_PATH SESSIONS_PATH TMP_PATH DOCUMENT_ROOT ARTIFACT_ROOT LLM_PROVIDER get_public_config get_public_config_gene get_public_config_at_path get_public_config_gene_at_path render_public_config_value secret_configured from "config")

(var expected ($env/EXPECTED_PROVIDER || "openai"))
(var public_config (get_public_config))
(var rendered (get_public_config_gene))
(var root_path_result (get_public_config_at_path ""))
(var provider_path_result (get_public_config_at_path "llm/provider"))
(var provider_path_result_slashed (get_public_config_at_path "/llm/provider/"))
(var home_root_result (get_public_config_at_path "home/root"))
(var home_state_root_result (get_public_config_at_path "home/state_root"))
(var sessions_root_result (get_public_config_at_path "home/sessions_root"))
(var tmp_root_result (get_public_config_at_path "home/tmp_root"))
(var uploaded_root_result (get_public_config_at_path "assets/uploaded_root"))
(var secret_path_result (get_public_config_at_path "llm/openai/api_key"))
(var missing_path_result (get_public_config_at_path "llm/missing"))
(var provider_gene (get_public_config_gene_at_path "llm/provider"))
(var port_gene (get_public_config_gene_at_path "port"))
(var base_url_gene (get_public_config_gene_at_path "llm/openai/base_url"))
(var llm_gene (get_public_config_gene_at_path "llm"))
(var missing_gene (get_public_config_gene_at_path "llm/missing"))
(var rendered_string_value (render_public_config_value "openai"))
(var rendered_int_value (render_public_config_value 4090))
(var rendered_bool_value (render_public_config_value true))

(var secret_values [
  ($env/OPENAI_API_KEY || "")
  ($env/ANTHROPIC_API_KEY || "")
  ($env/ANTHROPIC_AUTH_TOKEN || $env/ANTHROPIC_OAUTH_TOKEN || "")
  ($env/SLACK_SIGNING_SECRET || "")
  ($env/SLACK_BOT_TOKEN || "")
  ($env/SLACK_APP_TOKEN || "")
  ($env/SLACK_AGENTX_TOKEN || "")
  ($env/BRAVE_API_KEY || "")
])

(assert (LLM_PROVIDER == expected))
(assert (public_config/llm/provider == expected))
(assert (public_config/home/root == GENECLAW_HOME))
(assert (public_config/home/state_root == HOME_STATE_PATH))
(assert (public_config/home/sessions_root == SESSIONS_PATH))
(assert (public_config/home/tmp_root == TMP_PATH))
(assert (public_config/assets/uploaded_root == DOCUMENT_ROOT))
(assert (public_config/assets/generated_root == ARTIFACT_ROOT))
(assert (public_config/llm/openai/api_key == "hidden"))
(assert (public_config/llm/anthropic/api_key == "hidden"))
(assert (public_config/llm/anthropic/auth_token == "hidden"))
(assert (public_config/slack/signing_secret == "hidden"))
(assert (public_config/slack/bot_token == "hidden"))
(assert (public_config/slack/app_token == "hidden"))
(assert (public_config/slack/agentx_token == "hidden"))
(assert (public_config/search/brave_api_key == "hidden"))
(assert (public_config/llm/openai/api_key_configured == (secret_configured ($env/OPENAI_API_KEY || ""))))
(assert (public_config/llm/anthropic/api_key_configured == (secret_configured ($env/ANTHROPIC_API_KEY || ""))))
(assert (public_config/llm/anthropic/auth_token_configured == (secret_configured ($env/ANTHROPIC_AUTH_TOKEN || $env/ANTHROPIC_OAUTH_TOKEN || ""))))
(assert (public_config/slack/signing_secret_configured == (secret_configured ($env/SLACK_SIGNING_SECRET || ""))))
(assert (public_config/slack/bot_token_configured == (secret_configured ($env/SLACK_BOT_TOKEN || ""))))
(assert (public_config/slack/app_token_configured == (secret_configured ($env/SLACK_APP_TOKEN || ""))))
(assert (public_config/slack/agentx_token_configured == (secret_configured ($env/SLACK_AGENTX_TOKEN || ""))))
(assert (public_config/search/brave_api_key_configured == (secret_configured ($env/BRAVE_API_KEY || ""))))
(assert (rendered_string_value == "\"openai\""))
(assert (rendered_int_value == "4090"))
(assert (rendered_bool_value == "true"))
(assert (root_path_result/found == true))
(assert (provider_path_result/found == true))
(assert (provider_path_result/value == expected))
(assert (provider_path_result_slashed/found == true))
(assert (provider_path_result_slashed/value == expected))
(assert (home_root_result/found == true))
(assert (home_root_result/value == GENECLAW_HOME))
(assert (home_state_root_result/found == true))
(assert (home_state_root_result/value == HOME_STATE_PATH))
(assert (sessions_root_result/found == true))
(assert (sessions_root_result/value == SESSIONS_PATH))
(assert (tmp_root_result/found == true))
(assert (tmp_root_result/value == TMP_PATH))
(assert (uploaded_root_result/found == true))
(assert (uploaded_root_result/value == DOCUMENT_ROOT))
(assert (secret_path_result/found == true))
(assert (secret_path_result/value == "hidden"))
(assert (missing_path_result/found == false))
(assert (provider_gene == (render_public_config_value expected)))
(assert (port_gene == (public_config/port .to_s)))
(assert (base_url_gene == "\"\""))
(assert (llm_gene .contain "^provider"))
(assert (missing_gene == nil))
(assert (rendered .contain "^llm"))
(assert (rendered .contain "^slack"))
(assert (rendered .contain "hidden"))

(for secret in secret_values
  (if_not secret/.empty
    (assert ((rendered .contain secret) == false))
  )
)

(println "ok")
