#!/usr/bin/env gene run

(import MEMORY_ROOT from "config")
(import init_tools invoke_tool from "tools")

(system/shell #"rm -rf '#{MEMORY_ROOT}'")

(init_tools)

(var initial_read (invoke_tool "run-memory-tools" "ws-memory" "user-1" "chan-1" "" "session-memory" "memory_read" {^section "Decisions"}))
(assert (initial_read/ok == false))
(assert ((initial_read/error || "") .include? "Section not found"))

(var write_args {^section "Decisions" ^content "### 2026-03-18\n- Added memory system" ^mode "append"})
(var write_result (invoke_tool "run-memory-tools" "ws-memory" "user-1" "chan-1" "" "session-memory" "memory_write" write_args))
(assert (write_result/ok == true))

(var section_read (invoke_tool "run-memory-tools" "ws-memory" "user-1" "chan-1" "" "session-memory" "memory_read" {^section "Decisions"}))
(assert (section_read/ok == true))
(assert (section_read/result/.to_json .include? "Added memory system"))

(var search_result (invoke_tool "run-memory-tools" "ws-memory" "user-1" "chan-1" "" "session-memory" "memory_search" {^query "memory"}))
(assert (search_result/ok == true))
(assert (search_result/result/.to_json .include? "Decisions"))
(assert (search_result/result/.to_json .include? "Added memory system"))

(println "ok")
