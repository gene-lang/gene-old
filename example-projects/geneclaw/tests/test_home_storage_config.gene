#!/usr/bin/env gene run

(import GENECLAW_HOME HOME_STATE_PATH SESSIONS_PATH JOBS_PATH RUNS_PATH LOGS_PATH ARCHIVE_PATH TMP_PATH WORKSPACE_ROOT DOCUMENT_ROOT ARTIFACT_ROOT LLM_PROVIDER OPENAI_MODEL ANTHROPIC_AUTH_TOKEN MAX_STEPS DOCUMENT_MAX_INLINE_CHARS get_public_config get_public_config_at_path from "config")
(import get_system_prompt from "workspace_state")

(var expected_home ($env .get "GENECLAW_HOME" ""))
(var public_config (get_public_config))
(var provider_result (get_public_config_at_path "llm/provider"))
(var state_root_result (get_public_config_at_path "home/state_root"))
(var sessions_root_result (get_public_config_at_path "home/sessions_root"))
(var uploaded_root_result (get_public_config_at_path "assets/uploaded_root"))
(var db_path_result (get_public_config_at_path "db_path"))

(assert (GENECLAW_HOME == expected_home))
(assert (HOME_STATE_PATH == #"#{GENECLAW_HOME}/state"))
(assert (SESSIONS_PATH == #"#{GENECLAW_HOME}/sessions"))
(assert (JOBS_PATH == #"#{GENECLAW_HOME}/scheduler/jobs"))
(assert (RUNS_PATH == #"#{GENECLAW_HOME}/scheduler/runs"))
(assert (LOGS_PATH == #"#{GENECLAW_HOME}/logs"))
(assert (ARCHIVE_PATH == #"#{GENECLAW_HOME}/archive"))
(assert (TMP_PATH == #"#{GENECLAW_HOME}/tmp"))
(assert (WORKSPACE_ROOT == #"#{GENECLAW_HOME}/tmp"))
(assert (DOCUMENT_ROOT == #"#{GENECLAW_HOME}/assets/uploaded"))
(assert (ARTIFACT_ROOT == #"#{GENECLAW_HOME}/assets/generated"))

(assert (LLM_PROVIDER == "anthropic"))
(assert (OPENAI_MODEL == "gpt-5.1-mini"))
(assert (ANTHROPIC_AUTH_TOKEN == "oauth-home-token"))
(assert (MAX_STEPS == 9))
(assert (DOCUMENT_MAX_INLINE_CHARS == 2222))

(assert (public_config/home/root == expected_home))
(assert (public_config/home/state_root == #"#{expected_home}/state"))
(assert (public_config/home/sessions_root == #"#{expected_home}/sessions"))
(assert (public_config/assets/uploaded_root == #"#{expected_home}/assets/uploaded"))
(assert (provider_result/found == true))
(assert (provider_result/value == "anthropic"))
(assert (state_root_result/found == true))
(assert (state_root_result/value == #"#{expected_home}/state"))
(assert (sessions_root_result/found == true))
(assert (sessions_root_result/value == #"#{expected_home}/sessions"))
(assert (uploaded_root_result/found == true))
(assert (uploaded_root_result/value == #"#{expected_home}/assets/uploaded"))
(assert (db_path_result/found == false))
(assert (get_system_prompt/.call == "Prompt anthropic / gpt-5.1-mini / anthropic"))

(println "ok")
