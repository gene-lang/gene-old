#!/usr/bin/env gene run

(import GENECLAW_HOME HOME_WORKSPACE_PATH WORKSPACE_ROOT DOCUMENT_ROOT ARTIFACT_ROOT DB_PATH LLM_PROVIDER OPENAI_MODEL ANTHROPIC_AUTH_TOKEN MAX_STEPS DOCUMENT_MAX_INLINE_CHARS get_public_config get_public_config_at_path from "config")
(import get_system_prompt from "workspace_state")

(var expected_home ($env .get "GENECLAW_HOME" ""))
(var public_config (get_public_config))
(var provider_result (get_public_config_at_path "llm/provider"))
(var state_root_result (get_public_config_at_path "workspace/state_root"))

(assert (GENECLAW_HOME == expected_home))
(assert (HOME_WORKSPACE_PATH == #"#{GENECLAW_HOME}/workspace"))
(assert (WORKSPACE_ROOT == #"#{GENECLAW_HOME}/files"))
(assert (DOCUMENT_ROOT == #"#{GENECLAW_HOME}/documents"))
(assert (ARTIFACT_ROOT == #"#{GENECLAW_HOME}/artifacts"))
(assert (DB_PATH == #"#{GENECLAW_HOME}/geneclaw.sqlite"))

(assert (LLM_PROVIDER == "anthropic"))
(assert (OPENAI_MODEL == "gpt-5.1-mini"))
(assert (ANTHROPIC_AUTH_TOKEN == "oauth-home-token"))
(assert (MAX_STEPS == 9))
(assert (DOCUMENT_MAX_INLINE_CHARS == 2222))

(assert (public_config/home/root == expected_home))
(assert (public_config/workspace/state_root == #"#{expected_home}/workspace"))
(assert (provider_result/found == true))
(assert (provider_result/value == "anthropic"))
(assert (state_root_result/found == true))
(assert (state_root_result/value == #"#{expected_home}/workspace"))
(assert ((get_system_prompt) == "Prompt anthropic / gpt-5.1-mini / anthropic"))

(println "ok")
