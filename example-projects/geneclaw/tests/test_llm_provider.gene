#!/usr/bin/env gene run

(import build_anthropic_request normalize_anthropic_response from "llm_provider")

(var tools_spec [
  {^type "function"
   ^function {
     ^name "list_files"
     ^description "List files in a directory"
     ^parameters {
       ^type "object"
       ^properties {
         ^path {^type "string"}
       }
       ^required ["path"]
     }
   }}
])

(var history [
  {^role "assistant"
   ^content ""
   ^tool_calls [
     {^id "call_1"
      ^function {
        ^name "list_files"
        ^arguments "{\"path\":\"/tmp\"}"
      }}
   ]}
  {^role "tool"
   ^tool_call_id "call_1"
   ^content "{\"files\":[]}"}
])

(var request (build_anthropic_request history "Continue based on the tool results above." tools_spec))

(assert (request/system == "You are GeneClaw, a capable AI agent. You can use tools to complete tasks. After receiving a tool result, provide a natural response. For general conversation, respond normally without tool calls."))
(assert (request/tools/.size == 1))
(assert (request/tools/0/name == "list_files"))
(assert (request/tools/0/input_schema/properties/path/type == "string"))
(assert (request/messages/.size == 2))
(assert (request/messages/0/role == "assistant"))
(assert (request/messages/0/content/.size == 1))
(assert (request/messages/0/content/0/type == "tool_use"))
(assert (request/messages/0/content/0/id == "call_1"))
(assert (request/messages/0/content/0/name == "list_files"))
(assert (request/messages/0/content/0/input/path == "/tmp"))
(assert (request/messages/1/role == "user"))
(assert (request/messages/1/content/.size == 2))
(assert (request/messages/1/content/0/type == "tool_result"))
(assert (request/messages/1/content/0/tool_use_id == "call_1"))
(assert (request/messages/1/content/1/type == "text"))
(assert (request/messages/1/content/1/text == "Continue based on the tool results above."))

(var normalized (normalize_anthropic_response {
  ^content [
    {^type "text" ^text "Here are the files."}
    {^type "tool_use" ^id "toolu_1" ^name "list_files" ^input {^path "/tmp"}}
  ]
}))

(assert (normalized/content == "Here are the files."))
(assert (normalized/tool_calls/.size == 1))
(assert (normalized/tool_calls/0/id == "toolu_1"))
(assert (normalized/tool_calls/0/function/name == "list_files"))
(var parsed_args (gene/json/parse normalized/tool_calls/0/function/arguments))
(assert (parsed_args/path == "/tmp"))

(println "ok")
