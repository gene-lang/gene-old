#!/usr/bin/env gene run

(import build_openai_request build_anthropic_request error_message_from_response normalize_anthropic_response provider_supports_images? validate_image_inputs from "llm_provider")

(var tools_spec [
  {^type "function"
   ^function {
     ^name "list_files"
     ^description "List files in a directory"
     ^parameters {
       ^type "object"
       ^properties {
         ^path {^type "string"}
       }
       ^required ["path"]
     }
   }}
])

(var image_path "/tmp/geneclaw-test-image.png")
(gene/io/write image_path "fake-image-data")
(var image_attachment {
  ^document_id "doc-image-1"
  ^filename "screen.png"
  ^mime_type "image/png"
  ^local_path image_path
  ^byte_size 15
  ^status "staged"
})

(assert (((provider_supports_images? "openai") .to_s) == "true"))
(assert (((provider_supports_images? "anthropic") .to_s) == "true"))
(assert (((provider_supports_images? "bogus") .to_s) == "false"))
(var invalid_provider_check (validate_image_inputs [image_attachment] "bogus"))
(var invalid_provider_json (gene/json/stringify invalid_provider_check))
(assert (invalid_provider_json .include? "\"ok\":false"))
(assert (invalid_provider_json .include? "does not support image inputs"))

(var openai_request (build_openai_request [] "What is in this image?" tools_spec [image_attachment]))
(var openai_request_json (gene/json/stringify openai_request))
(assert (openai_request/messages/.size == 2))
(assert (openai_request/messages/1/role == "user"))
(assert (openai_request/messages/1/content/.size == 2))
(assert (openai_request/messages/1/content/0/type == "text"))
(assert (openai_request/messages/1/content/0/text == "What is in this image?"))
(assert (openai_request/messages/1/content/1/type == "image_url"))
(assert (openai_request_json .include? "\"type\":\"image_url\""))
(assert (openai_request_json .include? "\"data:image/png;base64,"))

(var history [
  {^role "assistant"
   ^content ""
   ^tool_calls [
     {^id "call_1"
      ^function {
        ^name "list_files"
        ^arguments "{\"path\":\"/tmp\"}"
      }}
   ]}
  {^role "tool"
   ^tool_call_id "call_1"
   ^content "{\"files\":[]}"}
])

(var request (build_anthropic_request history "Continue based on the tool results above." tools_spec [image_attachment]))
(var anthropic_request_json (gene/json/stringify request))

(assert (request/system == "You are GeneClaw, a capable AI agent. You can use tools to complete tasks. After receiving a tool result, provide a natural response. For general conversation, respond normally without tool calls."))
(assert (request/tools/.size == 1))
(assert (request/tools/0/name == "list_files"))
(assert (request/tools/0/input_schema/properties/path/type == "string"))
(assert (request/messages/.size == 2))
(assert (request/messages/0/role == "assistant"))
(assert (request/messages/0/content/.size == 1))
(assert (request/messages/0/content/0/type == "tool_use"))
(assert (request/messages/0/content/0/id == "call_1"))
(assert (request/messages/0/content/0/name == "list_files"))
(assert (request/messages/0/content/0/input/path == "/tmp"))
(assert (request/messages/1/role == "user"))
(assert (request/messages/1/content/.size == 3))
(assert (request/messages/1/content/0/type == "tool_result"))
(assert (request/messages/1/content/0/tool_use_id == "call_1"))
(assert (request/messages/1/content/1/type == "text"))
(assert (request/messages/1/content/1/text == "Continue based on the tool results above."))
(assert (anthropic_request_json .include? "\"type\":\"image\""))
(assert (anthropic_request_json .include? "\"media_type\":\"image/png\""))
(assert (anthropic_request_json .include? "\"type\":\"tool_result\""))

(var normalized (normalize_anthropic_response {
  ^content [
    {^type "text" ^text "Here are the files."}
    {^type "tool_use" ^id "toolu_1" ^name "list_files" ^input {^path "/tmp"}}
  ]
}))

(assert (normalized/content == "Here are the files."))
(assert (normalized/tool_calls/.size == 1))
(assert (normalized/tool_calls/0/id == "toolu_1"))
(assert (normalized/tool_calls/0/function/name == "list_files"))
(var parsed_args (gene/json/parse normalized/tool_calls/0/function/arguments))
(assert (parsed_args/path == "/tmp"))

(var anthropic_error_message (error_message_from_response {
  ^type "error"
  ^message "Anthropic API Error: Error"
  ^status 401
  ^raw_body "{\"type\":\"error\",\"error\":{\"type\":\"authentication_error\",\"message\":\"invalid x-api-key\"}}"
}))

(assert (anthropic_error_message .include? "Anthropic API Error: Error"))
(assert (anthropic_error_message .include? "status=401"))
(assert (anthropic_error_message .include? "body={\"type\":\"error\""))

(println "ok")
