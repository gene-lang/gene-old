#!/usr/bin/env gene run

(import image_attachment? text_document? build_document_context_text build_prompt_text build_memory_user_text append_document_notices from "documents")

(assert (image_attachment? "screen.png" "image/png"))
(assert (((image_attachment? "spec.pdf" "application/pdf") .to_s) == "false"))
(assert (text_document? "spec.pdf" "application/pdf"))

(var docs [
  {
    ^document_id "doc-1"
    ^filename "spec.pdf"
    ^byte_size 42
    ^status "extracted"
    ^extracted_text "Alpha beta gamma"
  }
  {
    ^document_id "doc-2"
    ^filename "screen.png"
    ^byte_size 128
    ^mime_type "image/png"
    ^status "staged"
    ^local_path "/tmp/screen.png"
  }
])

(var ingest {
  ^documents docs
  ^image_attachments [docs/1]
  ^usable_count 2
  ^notices ["notes.pdf: Unsupported document type"]
  ^context (build_document_context_text docs)
})

(assert (ingest/context .include? "Attached documents:"))
(assert (ingest/context .include? "spec.pdf"))
(assert ((build_prompt_text "summarize this" ingest) .include? "Analyze the attached images directly"))
(assert ((build_prompt_text "summarize this" ingest) .include? "Attachment preparation notices"))
(assert ((build_memory_user_text "summarize this" ingest) .include? "[Attached files: spec.pdf, screen.png]"))
(assert ((append_document_notices "done" ingest/notices) .include? "Attachment notices"))
(assert ((build_prompt_text "" {^documents docs ^image_attachments [docs/1] ^usable_count 1 ^notices [] ^context ""}) .include? "uploaded one or more images"))

(println "ok")
