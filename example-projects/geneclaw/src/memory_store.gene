# GeneClaw long-term memory store

(import CONFIG TMP_PATH from "config")
(import MEMORY_ROOT MEMORY_MARKDOWN_PATH MEMORY_INDEX_PATH ensure_home_bootstrap file_exists? read_record write_record_tree from "home_store")
(import ensure_array ensure_map from "config_helpers")

(var log (new genex/logging/Logger $ns))
($ns/EMBEDDING_MODEL = "text-embedding-3-small")
($ns/DEFAULT_SEARCH_LIMIT = 5)
($ns/DEFAULT_SEARCH_THRESHOLD = 0.3)
(var TOKEN_SPLIT_PATTERN #/[^a-z0-9]+/)
(var STOPWORDS {
  ^the true ^a true ^an true ^is true ^are true ^was true ^were true
  ^be true ^been true ^being true ^has true ^have true ^had true
  ^do true ^does true ^did true ^will true ^would true ^can true
  ^could true ^should true ^may true ^might true ^must true ^shall true
  ^to true ^of true ^in true ^for true ^on true ^with true ^at true
  ^by true ^from true ^and true ^or true ^not true ^but true ^if true
  ^then true ^so true ^that true ^this true ^it true ^its true ^i true
  ^my true ^me true ^we true ^our true ^you true ^your true ^he true
  ^she true ^they true ^them true ^his true ^her true ^their true
})
(var MEMORY_BUSY false)

(fn value_text [value fallback = ""]
  (if (value == nil)
    fallback
  elif (value is String)
    value
  else
    (try
      (value .to_s)
    catch *
      fallback
    )
  )
)

(fn truncate_text [text max_len = 240]
  (var raw ((text || "") .to_s))
  (if ((max_len <= 0) || (raw/.length <= max_len))
    raw
  elif (max_len <= 3)
    (raw .substr 0 max_len)
  else
    #"#{(raw .substr 0 (max_len - 3))}..."
  )
)

(fn structured_warning_payload? [text]
  (var raw (((text || "") .to_s) .trim))
  (if raw/.empty?
    false
  else
    (((raw .starts_with "{") || (raw .starts_with "{^")) &&
     ((raw .include? "\"data\"") ||
      (raw .include? "^data ") ||
      (raw .include? "\"embedding\"") ||
      (raw .include? "^embedding ") ||
      (raw .include? "\"model\"") ||
      (raw .include? "^model ")))
  )
)

(fn normalize_warning_text [warning fallback = ""]
  (var default_text ((fallback || "") .to_s))
  (var raw ((value_text warning default_text) .trim))
  (if raw/.empty?
    (return default_text)
  )
  (if (structured_warning_payload? raw)
    (return (if default_text/.empty?
      "unexpected response payload"
    else
      #"#{default_text}: unexpected response payload"
    ))
  )
  (truncate_text raw 240)
)

(fn record_value [record key fallback]
  (if record
    (record .get key fallback)
  else
    fallback
  )
)

(fn record_text [record key fallback = ""]
  (value_text (record_value record key fallback) fallback)
)

(fn record_bool [record key fallback = false]
  (var value (record_value record key fallback))
  (if (value == nil)
    fallback
  elif (value is Bool)
    value
  else
    fallback
  )
)

(fn merge_warning_messages [left right]
  (var left_text ((normalize_warning_text left "") .trim))
  (var right_text ((normalize_warning_text right "") .trim))
  (if left_text/.empty?
    right_text
  elif right_text/.empty?
    left_text
  elif (text_equals? left_text right_text)
    left_text
  else
    #"#{left_text}; #{right_text}"
  )
)

(fn ensure_memory_root []
  (ensure_home_bootstrap)
  (system/shell #"mkdir -p '#{MEMORY_ROOT}'")
)

(fn ensure_memory_markdown []
  (ensure_memory_root)
  (if_not (file_exists? MEMORY_MARKDOWN_PATH)
    (gene/io/write MEMORY_MARKDOWN_PATH "")
  )
  MEMORY_MARKDOWN_PATH
)

(fn read_memory_markdown_text []
  (ensure_memory_markdown)
  (try
    (var content (gene/io/read MEMORY_MARKDOWN_PATH))
    (if content
      (content .to_s)
    else
      ""
    )
  catch *
    ""
  )
)

(fn command_available? [name]
  (try
    (var probe (system/shell #"command -v #{name} >/dev/null 2>&1"))
    (probe/exit_code == 0)
  catch *
    false
  )
)

(fn file_sha256 [path]
  (var target ((path || "") .to_s))
  (if target/.empty?
    (return "")
  )

  (var command
    (if (command_available? "shasum")
      #"shasum -a 256 '#{target}' | awk '{print $1}'"
    elif (command_available? "sha256sum")
      #"sha256sum '#{target}' | awk '{print $1}'"
    else
      #"openssl dgst -sha256 '#{target}' | awk '{print $NF}'"
    )
  )

  (try
    (var result (system/shell command))
    (if (result/exit_code == 0)
      ((result/output || "") .to_s .trim)
    else
      ""
    )
  catch *
    ""
  )
)

(fn tmp_token []
  #"#{gene/now/.call/.to_i}-#{(math/random_int 99999 10000)}"
)

(fn text_sha256 [text]
  (ensure_memory_root)
  (var tmp_path #"#{TMP_PATH}/geneclaw-memory-hash-#{(tmp_token)}.txt")
  (try
    (gene/io/write tmp_path ((text || "") .to_s))
    (var digest (file_sha256 tmp_path))
    (system/shell #"rm -f '#{tmp_path}'")
    digest
  catch *
    (try
      (system/shell #"rm -f '#{tmp_path}'")
    catch *
      nil
    )
    ""
  )
)

(fn index_file_path []
  #"#{MEMORY_INDEX_PATH}.gene"
)

(fn index_tmp_path []
  #"#{MEMORY_ROOT}/.index.tmp"
)

(fn index_tmp_file_path []
  #"#{(index_tmp_path)}.gene"
)

(fn remove_index_file []
  (try
    (system/shell #"rm -f '#{(index_file_path)}' '#{(index_tmp_file_path)}'")
  catch *
    nil
  )
)

(fn read_index_record []
  (var record (read_record MEMORY_INDEX_PATH))
  (if record
    (ensure_map record)
  else
    nil
  )
)

(fn move_file [from_path to_path]
  (var result (system/shell #"mv '#{from_path}' '#{to_path}'"))
  (if (result/exit_code != 0)
    (throw #"Move failed: #{(result/output || "")}")
  )
  true
)

(fn with_memory_lock [action]
  (if MEMORY_BUSY
    (return {^ok false ^error "memory busy"})
  )
  (MEMORY_BUSY = true)
  (try
    (var result (action .call))
    (MEMORY_BUSY = false)
    result
  catch *
    (MEMORY_BUSY = false)
    (throw $ex)
  )
)

(fn section_heading_line [section]
  (["## " (((section || "") .to_s) .trim)] .join "")
)

(fn build_section_text [section content]
  (var heading (section_heading_line section))
  (var body (((content || "") .to_s) .trim))
  (if body/.empty?
    heading
  else
    #"#{heading}\n#{body}"
  )
)

(fn append_section_text [existing content]
  (var base ((existing || "") .to_s))
  (var addition (((content || "") .to_s) .trim))
  (if addition/.empty?
    (return base)
  )
  (if base/.empty?
    (return addition)
  )
  (if (base .ends_with "\n")
    #"#{base}#{addition}"
  else
    #"#{base}\n#{addition}"
  )
)

(fn text_equals? [left right]
  (var normalized_left (((left || "") .to_s) .trim))
  (var normalized_right (((right || "") .to_s) .trim))
  (if (normalized_left/.length != normalized_right/.length)
    (return false)
  )
  (if normalized_left/.empty?
    true
  else
    ((normalized_left .starts_with normalized_right) && (normalized_right .starts_with normalized_left))
  )
)

(fn chunk_markdown [text]
  (var source ((text || "") .to_s))
  (var lines (if source/.empty? [] else (source .split "\n")))
  (var raw_chunks [])
  (var preamble [])
  (var current_heading "")
  (var current_lines [])
  (var seen_heading false)

  (for line in lines
    (if (line .starts_with "## ")
      (if seen_heading
        (raw_chunks .append {^heading current_heading ^text (current_lines .join "\n")})
      elif preamble/.not_empty?
        (raw_chunks .append {^heading "" ^text (preamble .join "\n")})
      )
      (seen_heading = true)
      (current_heading = ((line .substr 3) .trim))
      (current_lines = [line])
    else
      (if seen_heading
        (current_lines .append line)
      else
        (preamble .append line)
      )
    )
  )

  (if seen_heading
    (raw_chunks .append {^heading current_heading ^text (current_lines .join "\n")})
  elif preamble/.not_empty?
    (raw_chunks .append {^heading "" ^text (preamble .join "\n")})
  )

  (var chunks [])
  (var offset 0)
  (var idx 0)
  (for chunk in raw_chunks
    (var chunk_text (record_text chunk "text" ""))
    (chunks .append {
      ^id idx
      ^heading (record_text chunk "heading" "")
      ^text chunk_text
      ^hash (text_sha256 chunk_text)
      ^offset offset
      ^length chunk_text/.length
    })
    (offset += chunk_text/.length)
    (if (idx < (raw_chunks/.size - 1))
      (offset += 1)
    )
    (idx += 1)
  )
  chunks
)

(fn join_chunks [chunks]
  (var parts [])
  (for chunk in (ensure_array chunks)
    (var text (record_text chunk "text" ""))
    (if text/.not_empty?
      (parts .append text)
    )
  )
  (parts .join "\n")
)

(fn find_section_index [chunks section]
  (var target (((section || "") .to_s) .trim))
  (var idx 0)
  (for chunk in (ensure_array chunks)
    (if (text_equals? (record_text chunk "heading" "") target)
      (return idx)
    )
    (idx += 1)
  )
  -1
)

(fn apply_section_update [current_text section content mode]
  (var resolved_section (((section || "") .to_s) .trim))
  (if resolved_section/.empty?
    (return {^ok false ^error "Missing section"})
  )

  (var resolved_mode (((mode || "append") .to_s) .trim))
  (var chunks (chunk_markdown current_text))
  (var section_index (find_section_index chunks resolved_section))

  (if (text_equals? resolved_mode "append")
    (if (section_index >= 0)
      (var existing (ensure_map (chunks .get section_index)))
      (existing/text = (append_section_text existing/text content))
      (chunks .set section_index existing)
    else
      (chunks .append {^heading resolved_section ^text (build_section_text resolved_section content)})
    )
  elif (text_equals? resolved_mode "replace")
    (var replacement {^heading resolved_section ^text (build_section_text resolved_section content)})
    (if (section_index >= 0)
      (chunks .set section_index replacement)
    else
      (chunks .append replacement)
    )
  elif (text_equals? resolved_mode "create")
    (if (section_index >= 0)
      (return {^ok false ^error #"Section already exists: #{resolved_section}"})
    )
    (chunks .append {^heading resolved_section ^text (build_section_text resolved_section content)})
  else
    (return {^ok false ^error #"Unsupported mode: #{resolved_mode}"})
  )

  {^ok true ^text (join_chunks chunks)}
)

(fn embedding_credentials_available? []
  (if_not genex/ai
    (return false)
  )
  ((CONFIG/llm/openai/embedding_api_key || "") .not_empty?)
)

(fn embedding_api_key []
  ((CONFIG/llm/openai/embedding_api_key || "") .to_s)
)

(fn build_embedding_client []
  (var client_opts {^model EMBEDDING_MODEL ^timeout_ms CONFIG/llm/openai/timeout_ms})
  (var resolved_api_key (embedding_api_key))
  (if resolved_api_key/.not_empty?
    (client_opts .set "api_key" resolved_api_key)
  )
  (if CONFIG/llm/openai/account_id/.not_empty?
    (client_opts .set "account_id" CONFIG/llm/openai/account_id)
  )
  (if CONFIG/llm/openai/base_url/.not_empty?
    (client_opts .set "base_url" CONFIG/llm/openai/base_url)
  )
  (new OpenAIClient client_opts)
)

(fn value_kind_name [value]
  (if (value == nil)
    "nil"
  elif (value is Array)
    "array"
  elif (value is Map)
    "map"
  elif (value is String)
    "string"
  elif (value is Bool)
    "bool"
  elif (value is Int)
    "int"
  elif (value is Float)
    "float"
  else
    "value"
  )
)

(fn map_keys_preview [record limit = 6]
  (if_not (record is Map)
    (return "")
  )
  (var names [])
  (var idx 0)
  (for key in record/.keys
    (if (idx >= limit)
      (break)
    )
    (names .append (((key || "") .to_s) .trim))
    (idx += 1)
  )
  (names .join ",")
)

(fn embedding_response_summary [response]
  (if_not (response is Map)
    (return #"response_kind=#{(value_kind_name response)}")
  )

  (var summary_parts [#"keys=#{(map_keys_preview response)}"])
  (var data_value ((response .get "data" nil) || nil))
  (summary_parts .append #"data_kind=#{(value_kind_name data_value)}")

  (if ((data_value is Array) && data_value/.not_empty?)
    (var first_item (ensure_map (data_value .get 0)))
    (summary_parts .append #"first_keys=#{(map_keys_preview first_item)}")
    (var embedding_value ((first_item .get "embedding" nil) || nil))
    (if (embedding_value is Array)
      (summary_parts .append #"embedding_size=#{embedding_value/.size}")
    )
  elif (data_value is Map)
    (var data_map (ensure_map data_value))
    (summary_parts .append #"data_keys=#{(map_keys_preview data_map)}")
    (var embedding_value ((data_map .get "embedding" nil) || nil))
    (if (embedding_value is Array)
      (summary_parts .append #"embedding_size=#{embedding_value/.size}")
    )
  elif ((response .get "embedding" nil) is Array)
    (summary_parts .append #"embedding_size=#{((response .get "embedding" []) .size)}")
  )

  (summary_parts .join " ")
)

(fn extract_embedding_vector [response]
  (if_not (response is Map)
    (return {^ok false ^summary (embedding_response_summary response)})
  )

  (var data_value ((response .get "data" nil) || nil))
  (if ((data_value is Array) && data_value/.not_empty?)
    (var first_item (ensure_map (data_value .get 0)))
    (var embedding_value (ensure_array ((first_item .get "embedding" []) || [])))
    (if embedding_value/.not_empty?
      (return {^ok true ^vector embedding_value})
    )
  elif (data_value is Map)
    (var data_map (ensure_map data_value))
    (var embedding_value (ensure_array ((data_map .get "embedding" []) || [])))
    (if embedding_value/.not_empty?
      (return {^ok true ^vector embedding_value})
    )
  )

  (var top_level_embedding (ensure_array ((response .get "embedding" []) || [])))
  (if top_level_embedding/.not_empty?
    (return {^ok true ^vector top_level_embedding})
  )

  {^ok false ^summary (embedding_response_summary response)}
)

(fn embedding_error_message [response]
  (if (response is OpenAIError)
    (var message (normalize_warning_text (response/message || response/provider_error || response/raw_body || (response .to_s)) "Embedding request failed"))
    (if message/.not_empty?
      (return message)
    )
    (return "Embedding request failed")
  )
  (if_not (response is Map)
    (return "Embedding request failed")
  )
  (var error_map (if (response/error is Map) response/error else nil))
  (if error_map
    (var message (normalize_warning_text (record_text error_map "message" "") "Embedding request failed"))
    (if message/.not_empty?
      (return message)
    )
  )
  (if (text_equals? ((response/type || "") .to_s) "error")
    (return (normalize_warning_text (record_text response "message" "") "Embedding request failed"))
  )
  ""
)

(fn embed_text [text]
  (if_not (embedding_credentials_available?)
    (return {^ok false ^error "memory_search unavailable: OpenAI credentials not configured"})
  )
  (var client (build_embedding_client))
  (var response (client .embeddings {^model EMBEDDING_MODEL ^input ((text || "") .to_s) ^encoding_format "float"}))
  (var extracted (extract_embedding_vector response))
  (if extracted/ok
    (return {^ok true ^vector extracted/vector})
  )
  (var error_message (embedding_error_message response))
  (if error_message/.not_empty?
    (return {^ok false ^error error_message})
  )
  (var summary ((extracted/summary || "") .to_s))
  (if summary/.not_empty?
    (return {^ok false ^error #"Embedding request returned no vector (#{summary})"})
  )
  {^ok false ^error "Embedding request returned no vector"}
)

(fn build_reuse_map [index]
  (var reuse {})
  (var current (ensure_map (if index index else {})))
  (if_not (text_equals? (record_text current "model" "") EMBEDDING_MODEL)
    (return reuse)
  )
  (for chunk in (ensure_array (current/chunks || []))
    (var normalized (ensure_map chunk))
    (var hash (record_text normalized "hash" ""))
    (var vector (ensure_array (normalized/vector || [])))
    (if (hash/.not_empty? && vector/.not_empty?)
      (reuse .set hash vector)
    )
  )
  reuse
)

(fn tokenize [text]
  (var words ((((text || "") .to_s) .downcase) .split TOKEN_SPLIT_PATTERN))
  (var tokens [])
  (for raw_word in words
    (var word (((raw_word || "") .to_s) .trim))
    (if ((word/.length > 2) && (not (STOPWORDS .get word false)))
      (tokens .append word)
    )
  )
  tokens
)

(fn count_tokens [tokens]
  (var counts {})
  (for token in (ensure_array tokens)
    (var key (((token || "") .to_s) .trim))
    (if key/.not_empty?
      (counts .set key ((counts .get key 0) + 1))
    )
  )
  counts
)

(fn unique_tokens [tokens]
  (var seen {})
  (var result [])
  (for token in (ensure_array tokens)
    (var key (((token || "") .to_s) .trim))
    (if (key/.not_empty? && (not (seen .get key false)))
      (seen .set key true)
      (result .append key)
    )
  )
  result
)

(fn keyword_coverage [query_terms token_counts]
  (var terms (ensure_array query_terms))
  (if terms/.empty?
    (return 0.0)
  )
  (var matched 0.0)
  (var counts (ensure_map (if token_counts token_counts else {})))
  (for term in terms
    (var token_name (((term || "") .to_s) .trim))
    (if (((counts .get token_name 0) .to_f) > 0.0)
      (matched += 1.0)
    )
  )
  (matched / terms/.size/.to_f)
)

(fn bm25_score [query_terms chunk doc_freq total_chunks avg_doc_len]
  (var terms (ensure_array query_terms))
  (if (terms/.empty? || (total_chunks <= 0))
    (return 0.0)
  )

  (var normalized_chunk (ensure_map (if chunk chunk else {})))
  (var token_counts (ensure_map (record_value normalized_chunk "token_counts" {})))
  (var doc_len (record_value normalized_chunk "token_count" 0))
  (var safe_avg_doc_len (if (avg_doc_len > 0.0) avg_doc_len else 1.0))
  (var score 0.0)

  (for term in terms
    (var token_name (((term || "") .to_s) .trim))
    (var tf ((token_counts .get token_name 0) .to_f))
    (if (tf > 0.0)
      (var df ((doc_freq .get token_name 0) .to_f))
      (var numerator ((total_chunks/.to_f - df) + 0.5))
      (var denominator (df + 0.5))
      (var idf_input ((numerator / denominator) + 1.0))
      (var idf (math/log idf_input))
      (var doc_ratio (doc_len/.to_f / safe_avg_doc_len))
      (var tf_denom (tf + (1.2 * (0.25 + (0.75 * doc_ratio)))))
      (var tf_norm ((tf * 2.2) / tf_denom))
      (score += (* idf tf_norm))
    )
  )

  (if (score <= 0.0)
    0.0
  else
    (score * (1.0 + (keyword_coverage terms token_counts)))
  )
)

(fn keyword_index_ready? [index]
  (if_not index
    (return false)
  )
  (var current (ensure_map index))
  (if ((record_value current "doc_freq" nil) == nil)
    (return false)
  )
  (if ((record_value current "total_chunks" nil) == nil)
    (return false)
  )
  (var chunks (ensure_array (current/chunks || [])))
  (if chunks/.empty?
    true
  else
    (var first_chunk (ensure_map (chunks .get 0)))
    (not (((record_value first_chunk "tokens" nil) == nil) || ((record_value first_chunk "token_counts" nil) == nil)))
  )
)

(fn index_has_embeddings? [index]
  (if_not index
    (return false)
  )
  (var current (ensure_map index))
  (if_not (text_equals? (record_text current "model" "") EMBEDDING_MODEL)
    (return false)
  )
  (for chunk in (ensure_array (current/chunks || []))
    (var normalized (ensure_map chunk))
    (var vector (ensure_array (normalized/vector || [])))
    (if vector/.not_empty?
      (return true)
    )
  )
  false
)

(fn build_index_for_text [text old_index = nil]
  (var source ((text || "") .to_s))
  (var chunks (chunk_markdown source))
  (var reuse_vectors (build_reuse_map old_index))
  (var indexed_chunks [])
  (var doc_freq {})
  (var total_token_count 0)
  (var dimensions 0)
  (var embedding_warning "")
  (var stop_embedding false)
  (var want_embeddings (embedding_credentials_available?))

  (for chunk in chunks
    (var normalized (ensure_map chunk))
    (var tokens (tokenize (normalized/text || "")))
    (var token_counts (count_tokens tokens))
    (total_token_count += tokens/.size)
    (for token in token_counts/.keys
      (var token_name (((token || "") .to_s) .trim))
      (if token_name/.not_empty?
        (doc_freq .set token_name ((doc_freq .get token_name 0) + 1))
      )
    )

    (var vector (reuse_vectors .get (normalized/hash || "") nil))
    (if (want_embeddings && (vector == nil) && (stop_embedding == false))
      (var embedding (embed_text normalized/text))
      (if embedding/ok
        (vector = embedding/vector)
      else
        (stop_embedding = true)
        (embedding_warning = (normalize_warning_text (embedding/error || "Embedding index build failed") "Embedding index build failed"))
        (log .warn #"memory index embedding refresh skipped: #{embedding_warning}")
      )
    )
    (if ((dimensions == 0) && (vector is Array))
      (dimensions = vector/.size)
    )
    (indexed_chunks .append {
      ^id normalized/id
      ^heading (normalized/heading || "")
      ^text (normalized/text || "")
      ^hash (normalized/hash || "")
      ^tokens tokens
      ^token_counts token_counts
      ^token_count tokens/.size
      ^vector vector
      ^offset (normalized/offset || 0)
      ^length (normalized/length || 0)
    })
  )

  (var avg_doc_len (if indexed_chunks/.not_empty? (/ total_token_count/.to_f indexed_chunks/.size) else 0.0))
  {^ok true ^index {
    ^file_hash (text_sha256 source)
    ^model (if (dimensions > 0) EMBEDDING_MODEL else "")
    ^dimensions dimensions
    ^doc_freq doc_freq
    ^total_chunks indexed_chunks/.size
    ^avg_doc_len avg_doc_len
    ^chunks indexed_chunks
  } ^warning embedding_warning}
)

(fn commit_markdown_and_index [markdown_text index]
  (ensure_memory_root)
  (var markdown_tmp #"#{MEMORY_ROOT}/MEMORY.md.tmp")
  (var markdown_target MEMORY_MARKDOWN_PATH)
  (var file_hash (text_sha256 markdown_text))
  (var reindexed false)
  (var warning "")

  (gene/io/write markdown_tmp markdown_text)
  (move_file markdown_tmp markdown_target)

  (if index
    (try
      (write_record_tree (index_tmp_path) index)
      (move_file (index_tmp_file_path) (index_file_path))
      (reindexed = true)
    catch *
      (warning = (normalize_warning_text #"Index refresh failed: #{$ex/message}" "Index refresh failed"))
      (remove_index_file)
    )
  else
    (remove_index_file)
  )

  {^ok true ^file_hash file_hash ^reindexed reindexed ^warning warning}
)

(fn ensure_index_current []
  (var markdown_text (read_memory_markdown_text))
  (var markdown_hash (text_sha256 markdown_text))
  (var index (read_index_record))
  (var want_embeddings (embedding_credentials_available?))
  (if (index &&
       (text_equals? (record_text index "file_hash" "") markdown_hash) &&
       (keyword_index_ready? index) &&
       ((not want_embeddings) || (index_has_embeddings? index)))
    (return {^ok true ^index index ^rebuilt false})
  )

  (with_memory_lock (fn []
    (var latest_text (read_memory_markdown_text))
    (var latest_hash (text_sha256 latest_text))
    (var latest_index (read_index_record))
    (var latest_want_embeddings (embedding_credentials_available?))
    (if (latest_index &&
         (text_equals? (record_text latest_index "file_hash" "") latest_hash) &&
         (keyword_index_ready? latest_index) &&
         ((not latest_want_embeddings) || (index_has_embeddings? latest_index)))
      (return {^ok true ^index latest_index ^rebuilt false})
    )

    (var built (build_index_for_text latest_text latest_index))
    (var commit (commit_markdown_and_index latest_text built/index))
    (if_not commit/ok
      (return commit)
    )
    {^ok true
     ^index built/index
     ^rebuilt commit/reindexed
     ^warning (merge_warning_messages (built/warning || "") (commit/warning || ""))}
  ))
)

(fn cosine_similarity [a b]
  (var left (ensure_array (if a a else [])))
  (var right (ensure_array (if b b else [])))
  (if ((left/.size == 0) || (right/.size == 0) || (left/.size != right/.size))
    (return 0.0)
  )
  (var dot 0.0)
  (var norm_a 0.0)
  (var norm_b 0.0)
  (var i 0)
  (while (i < left/.size)
    (var left_i (left .get i))
    (var right_i (right .get i))
    (dot = (dot + (left_i * right_i)))
    (norm_a = (norm_a + (left_i * left_i)))
    (norm_b = (norm_b + (right_i * right_i)))
    (i += 1)
  )
  (if ((norm_a == 0.0) || (norm_b == 0.0))
    0.0
  else
    (dot / ((math/sqrt norm_a) * (math/sqrt norm_b)))
  )
)

(fn sort_results_by_score [results]
  (var items [])
  (for item in (ensure_array results)
    (items .append item)
  )

  (var i 0)
  (while (i < items/.size)
    (var best i)
    (var j (i + 1))
    (while (j < items/.size)
      (var candidate_item (ensure_map (items .get j)))
      (var best_item (ensure_map (items .get best)))
      (var candidate (candidate_item .get "score" 0.0))
      (var current_best (best_item .get "score" 0.0))
      (if (candidate > current_best)
        (best = j)
      )
      (j += 1)
    )
    (if (best != i)
      (var tmp (items .get i))
      (items .set i (items .get best))
      (items .set best tmp)
    )
    (i += 1)
  )
  items
)

(fn limit_results [results limit]
  (if (limit <= 0)
    (return [])
  )
  (if (results/.size > limit)
    (results .slice 0 limit)
  else
    results
  )
)

(fn search_embedding [query_vector index limit threshold]
  (var ensured_index (ensure_map (if index index else {})))
  (var indexed_chunks (ensure_array (ensured_index .get "chunks" [])))
  (var results [])
  (for chunk in indexed_chunks
    (var normalized (ensure_map chunk))
    (var vector (ensure_array (normalized/vector || [])))
    (if vector/.not_empty?
      (var score (cosine_similarity query_vector vector))
      (if (score >= threshold)
        (results .append {
          ^heading (normalized/heading || "")
          ^text (normalized/text || "")
          ^score score
        })
      )
    )
  )
  (results = (sort_results_by_score results))
  (limit_results results limit)
)

(fn search_keyword [query index limit threshold]
  (var ensured_index (ensure_map (if index index else {})))
  (var query_terms (unique_tokens (tokenize query)))
  (if query_terms/.empty?
    (return [])
  )

  (var indexed_chunks (ensure_array (ensured_index .get "chunks" [])))
  (var doc_freq (ensure_map (ensured_index .get "doc_freq" {})))
  (var total_chunks (ensured_index .get "total_chunks" indexed_chunks/.size))
  (var avg_doc_len ((ensured_index .get "avg_doc_len" 0.0) .to_f))
  (if (avg_doc_len <= 0.0)
    (var total_token_count 0)
    (for chunk in indexed_chunks
      (var normalized (ensure_map chunk))
      (total_token_count += (record_value normalized "token_count" 0))
    )
    (avg_doc_len = (if (total_chunks > 0) (/ total_token_count/.to_f total_chunks) else 0.0))
  )

  (var results [])
  (for chunk in indexed_chunks
    (var normalized (ensure_map chunk))
    (var score (bm25_score query_terms normalized doc_freq total_chunks avg_doc_len))
    (if (score >= threshold)
      (results .append {
        ^heading (normalized/heading || "")
        ^text (normalized/text || "")
        ^score score
      })
    )
  )

  (results = (sort_results_by_score results))
  (limit_results results limit)
)

(fn $ns/memory_read [section = nil]
  (var markdown_text (read_memory_markdown_text))
  (var requested (((section || "") .to_s) .trim))
  (if requested/.empty?
    (return {^ok true ^content markdown_text})
  )

  (var chunks (chunk_markdown markdown_text))
  (var idx (find_section_index chunks requested))
  (if (idx < 0)
    (return {^ok false ^error #"Section not found: #{requested}"})
  )
  (var chunk (ensure_map (chunks .get idx)))
  {^ok true ^section requested ^content (chunk/text || "")}
)

(fn $ns/memory_write [section content mode = "append"]
  (var requested (((section || "") .to_s) .trim))
  (if requested/.empty?
    (return {^ok false ^error "Missing section"})
  )
  (var body_text (if (content == nil) "" else (content .to_s)))
  (var resolved_mode (((mode || "append") .to_s) .trim))

  (with_memory_lock (fn []
    (var current_text (read_memory_markdown_text))
    (var updated (apply_section_update current_text requested body_text resolved_mode))
    (if_not updated/ok
      (return updated)
    )

    (var build_result (build_index_for_text updated/text (read_index_record)))
    (var built_index build_result/index)

    (var committed (commit_markdown_and_index updated/text built_index))
    (if_not committed/ok
      (return committed)
    )
    {
      ^ok true
      ^section requested
      ^mode resolved_mode
      ^file_hash committed/file_hash
      ^reindexed committed/reindexed
      ^warning (merge_warning_messages (build_result/warning || "") (committed/warning || ""))
    }
  ))
)

(fn $ns/memory_search [query limit = DEFAULT_SEARCH_LIMIT threshold = DEFAULT_SEARCH_THRESHOLD]
  (var query_text (((query || "") .to_s) .trim))
  (if query_text/.empty?
    (return {^ok false ^error "Missing query"})
  )

  (var markdown_text (read_memory_markdown_text))
  (if markdown_text/.trim/.empty?
    (return {^ok true ^results [] ^count 0})
  )

  (var ensured (ensure_index_current))
  (if_not ensured/ok
    (return ensured)
  )

  (var ensured_index (ensure_map (ensured .get "index" {})))
  (var warning_text (normalize_warning_text (ensured/warning || "") ""))
  (if warning_text/.not_empty?
    (log .warn #"memory_search index warning: #{warning_text}")
  )

  (var results [])
  (if (embedding_credentials_available? && (index_has_embeddings? ensured_index))
    (var embedded_query (embed_text query_text))
    (if embedded_query/ok
      (results = (search_embedding embedded_query/vector ensured_index limit threshold))
    else
      (log .warn #"memory_search embedding query failed, falling back to keyword search: #{embedded_query/error}")
    )
  )

  (if results/.empty?
    (results = (search_keyword query_text ensured_index limit threshold))
  )

  {^ok true ^results results ^count results/.size ^rebuilt (record_bool ensured "rebuilt" false)}
)
