# GeneClaw Agent Orchestrator
# Provider-agnostic tool calling: provider translation lives in llm_provider.gene

(import MAX_STEPS MAX_TOOL_CALLS from "config")
(import memory_append memory_recent from "db")
(import run_complete from "db")
(import invoke_tool build_tools_spec from "tools")
(import is_paused check_pause_timeout get_pause_status from "hotswap_state")
(import call_llm from "llm_provider")
(import ingest_attachments build_prompt_text build_memory_user_text append_document_notices from "documents")

(var log (new genex/logging/Logger $ns))
(var RUN_COUNTER 0)

(fn make_run_id []
  (RUN_COUNTER += 1)
  #"run-#{RUN_COUNTER}"
)

(fn $ns/build_session_id [workspace_id channel_id thread_id = ""]
  (var thread_part (if thread_id then (thread_id .to_s) else ""))
  (if ((thread_part .length) > 0)
    #"#{workspace_id}:#{channel_id}:#{thread_part}"
  else
    #"#{workspace_id}:#{channel_id}"
  )
)

# Keep the LLM/tool loop in a helper. Re-entering the larger run_agent frame
# after repeated LLM calls was corrupting subsequent history loads.
(fn execute_agent_steps [run_id workspace_id user_id channel_id thread_id session_id history initial_text tools_spec image_attachments]
  (var step 0)
  (var tool_call_count 0)
  (var final_response "")
  (var text initial_text)

  (loop
    (if (step >= MAX_STEPS)
      (log .warn #"#{run_id} hit MAX_STEPS limit (#{MAX_STEPS})")
      (final_response = "Agent reached maximum step limit.")
      (break)
    )
    (step += 1)
    (log .info #"#{run_id} step #{step}/#{MAX_STEPS}")

    # Build provider request and call the selected LLM provider
    (var result (call_llm history text tools_spec image_attachments))
    (var content result/content)
    (var tool_calls result/tool_calls)

    # No tool calls -> final response
    (if (tool_calls/.size == 0)
      (log .debug #"#{run_id} no tool calls - final response")
      (final_response = content)
      (break)
    )

    # Dispatch each tool call
    (if (tool_call_count >= MAX_TOOL_CALLS)
      (log .warn #"#{run_id} hit MAX_TOOL_CALLS limit (#{MAX_TOOL_CALLS})")
      (final_response = "Agent reached maximum tool call limit.")
      (break)
    )

    # Add assistant message with tool_calls to history
    (history .append {^role "assistant" ^content content ^tool_calls tool_calls})

    (tool_calls .each (fn [tc]
      (tool_call_count += 1)
      (var fn_info tc/function)
      (var tool_name fn_info/name)
      (var tool_args_str fn_info/arguments)
      (log .info #"#{run_id} dispatching tool #{tool_call_count}/#{MAX_TOOL_CALLS}: #{tool_name}")

      # Parse arguments JSON string; coerce to map for tool handlers.
      (var parsed_args (try (gene/json/parse tool_args_str) catch * nil))
      (var tool_args (if (parsed_args is Map) parsed_args else {}))
      (var tool_result (invoke_tool run_id workspace_id user_id channel_id thread_id session_id tool_name tool_args))

      # Build result text
      (var result_text (if tool_result/ok
        tool_result/result/.to_json
      else
        #"Error: #{tool_result/error}"
      ))
      (log .debug #"#{run_id} tool result: #{result_text}")

      # Add tool result message with tool_call_id (OpenAI format)
      (history .append {^role "tool" ^tool_call_id tc/id ^content result_text})
    ))

    # Update text for next iteration context
    (text = "Continue based on the tool results above.")
  )

  {^response final_response ^steps step ^tool_calls tool_call_count}
)

# --- Main agent run ---

(fn normalize_envelope [envelope]
  (var input (if (envelope is Map) envelope else {}))
  {^workspace_id (input/workspace_id || "default")
   ^user_id (input/user_id || "anonymous")
   ^channel_id (input/channel_id || "general")
   ^thread_id (input/thread_id || input/thread_ts || "")
   ^text (input/text || "")
   ^attachments (if (input/attachments is Array) input/attachments else [])
   ^metadata (if (input/metadata is Map) input/metadata else {})}
)

(fn paused_memory_text [text attachment_count]
  (if ((((text || "") .to_s) .length == 0) && (attachment_count > 0))
    "[Uploaded documents]"
  elif (attachment_count > 0)
    #"#{text}\n\n[Attached documents]"
  else
    text
  )
)

(fn $ns/run_agent_envelope [envelope]
  (var input (normalize_envelope envelope))
  (var workspace_id input/workspace_id)
  (var user_id input/user_id)
  (var channel_id input/channel_id)
  (var thread_id input/thread_id)
  (var text ((input/text || "") .to_s))
  (var attachment_count input/attachments/.size)
  (var run_id (make_run_id))
  (var session_id (build_session_id workspace_id channel_id thread_id))

  (log .info #"=== Agent run started: #{run_id} ===")
  (if ((((thread_id || "") .to_s) .length) == 0)
    (log .info #"workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} attachments=#{attachment_count}")
  else
    (log .info #"workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} thread=#{thread_id} attachments=#{attachment_count}")
  )
  (log .debug #"Input text: #{text}")

  # If paused, do not execute LLM/tool pipeline.
  (check_pause_timeout)
  (if (is_paused)
    (var pause_status (get_pause_status))
    (var paused_response "GeneClaw is paused for self-upgrade. Please retry shortly.")
    (memory_append workspace_id session_id "user" (paused_memory_text text attachment_count) {^user_id user_id ^attachments attachment_count})
    (memory_append workspace_id session_id "assistant" paused_response {^run_id run_id ^paused true})
    (run_complete run_id "paused" nil)
    (log .warn #"#{run_id} skipped: paused reason=#{pause_status/pause_reason}")
    (return {^run_id run_id ^response paused_response ^steps 0 ^tool_calls 0 ^paused true ^pause_status pause_status})
  )

  # Load conversation history
  (var history (memory_recent session_id 20))
  (log .info #"Loaded #{history/.size} history entries for session #{session_id}")

  (var ingest (ingest_attachments session_id input))
  (if (attachment_count > 0)
    (log .info #"#{run_id} ingested #{attachment_count} attachment(s), usable=#{ingest/usable_count}, images=#{(if (ingest/image_attachments is Array) ingest/image_attachments/.size else 0)}")
  )
  (var prompt_text (build_prompt_text text ingest))
  (var memory_text (build_memory_user_text text ingest))

  # Record user message
  (memory_append workspace_id session_id "user" memory_text {
    ^user_id user_id
    ^attachments attachment_count
    ^usable_attachments (ingest/usable_count || 0)
    ^image_attachments (if (ingest/image_attachments is Array) ingest/image_attachments/.size else 0)
  })

  (var tools_spec (build_tools_spec))
  (var phase (execute_agent_steps run_id workspace_id user_id channel_id thread_id session_id history prompt_text tools_spec (ingest/image_attachments || [])))
  (var final_response (append_document_notices phase/response (ingest/notices || [])))
  (var step phase/steps)
  (var tool_call_count phase/tool_calls)

  # Record agent response
  (memory_append workspace_id session_id "assistant" final_response {^run_id run_id})
  (run_complete run_id "completed" nil)

  (log .info #"=== Agent run completed: #{run_id} steps=#{step} tool_calls=#{tool_call_count} response_len=#{final_response/.length} ===")

  {^run_id run_id ^response final_response ^steps step ^tool_calls tool_call_count}
)

(fn $ns/run_agent [workspace_id user_id channel_id text thread_id = ""]
  (run_agent_envelope {
    ^workspace_id workspace_id
    ^user_id user_id
    ^channel_id channel_id
    ^thread_id thread_id
    ^text text
    ^attachments []
  })
)
