# GeneClaw Agent Orchestrator
# Native OpenAI tool calling: structured tool specs, no text-based JSON parsing

(import OPENAI_API_KEY OPENAI_MODEL OPENAI_BASE_URL OPENAI_TIMEOUT_MS MAX_STEPS MAX_TOOL_CALLS from "config")
(import memory_append memory_recent from "db")
(import run_create run_complete from "db")
(import invoke_tool build_tools_spec from "tools")
(import is_paused check_pause_timeout get_pause_status from "hotswap_state")

(var log (new genex/logging/Logger $ns))
(var RUN_COUNTER 0)

(fn make_run_id []
  (RUN_COUNTER += 1)
  #"run-#{RUN_COUNTER}"
)

(fn build_messages [history user_text]
  (var messages [])

  # System prompt - no tool listing needed, OpenAI handles that natively
  (var system_text "You are GeneClaw, a capable AI agent. You can use tools to complete tasks. After receiving a tool result, provide a natural response. For general conversation, respond normally without tool calls.")

  (messages .append {^role "system" ^content system_text})

  # Conversation history
  (history .each (fn [entry]
    (var msg {^role entry/role ^content (entry/content || "")})
    (if (entry/role == "assistant")
      (if entry/tool_calls
        (msg .set "tool_calls" entry/tool_calls)
      )
    elif (entry/role == "tool")
      (if entry/tool_call_id
        (msg .set "tool_call_id" entry/tool_call_id)
      )
    )
    (messages .append msg)
  ))

  # Current user message
  (messages .append {^role "user" ^content user_text})

  # Log full content sent to LLM
  (log .info #"Built #{messages/.size} messages (#{history/.size} history + system + user)")
  (var msg_idx 0)
  (messages .each (fn [msg]
    (log .info #"--- Message #{msg_idx} [#{msg/role}] ---")
    (log .info msg/content)
    (msg_idx += 1)
  ))
  (log .info "--- End of messages ---")
  messages
)

(fn call_llm [messages tools_spec]
  # Call OpenAI-compatible API with native tool calling
  (if OPENAI_API_KEY/.empty
    # Mock mode
    (log .info "LLM call skipped (mock mode - no API key)")
    (return {^content "I received your message. (Running in mock mode - set OPENAI_API_KEY to enable LLM)" ^tool_calls []})
  )

  (if genex/ai
    (try
      (log .info #"Calling LLM model=#{OPENAI_MODEL} messages=#{messages/.size} tools=#{tools_spec/.size} timeout_ms=#{OPENAI_TIMEOUT_MS}")
      (var start_ms gene/now/.call/.to_i)
      (var client_opts {^api_key OPENAI_API_KEY ^model OPENAI_MODEL ^timeout_ms OPENAI_TIMEOUT_MS})
      (if_not OPENAI_BASE_URL/.empty
        (client_opts .set "base_url" OPENAI_BASE_URL)
      )
      (var client (new OpenAIClient client_opts))
      (var response (client .chat {^messages messages ^tools tools_spec}))
      (log .debug "LLM chat returned")
      (var duration (gene/now/.call/.to_i - start_ms))
      (if response
        # OpenAI bindings return an OpenAIError instance on transport/API failures.
        (var error_message response/message)
        (if error_message
          (log .error #"LLM call failed: #{error_message}")
          (return {^content #"LLM error: #{error_message}" ^tool_calls []})
        )
        (var choices (try (response .get "choices" []) catch * []))
        (if (choices/.size > 0)
          (var first_choice choices/0)
          (var msg first_choice/message)
          (var content ((msg .get "content" "") .to_s))
          (var tool_calls (msg .get "tool_calls" []))
          (if_not tool_calls (tool_calls = []))
          (log .info #"LLM responded in #{duration}ms content_len=#{content/.size} tool_calls=#{tool_calls/.size}")
          (log .trace #"LLM response: #{content}")
          (return {^content content ^tool_calls tool_calls})
        )
      )
      (log .warn #"LLM returned empty response after #{duration}ms")
      {^content "I could not generate a response." ^tool_calls []}
    catch *
      (log .error #"LLM call failed: #{$ex/message}")
      {^content #"LLM error: #{$ex/message}" ^tool_calls []}
    )
  else
    (log .error "genex/ai module unavailable")
    {^content "genex/ai module unavailable." ^tool_calls []}
  )
)

# --- Main agent run ---

(fn $ns/run_agent [workspace_id user_id channel_id text]
  (var run_id (make_run_id))
  (var session_id #"#{workspace_id}:#{channel_id}")

  (log .info #"=== Agent run started: #{run_id} ===")
  (log .info #"workspace=#{workspace_id} user=#{user_id} channel=#{channel_id}")
  (log .debug #"Input text: #{text}")

  # Record run start
  (run_create run_id workspace_id user_id)

  # If paused, do not execute LLM/tool pipeline.
  (check_pause_timeout)
  (if (is_paused)
    (var pause_status (get_pause_status))
    (var paused_response "GeneClaw is paused for self-upgrade. Please retry shortly.")
    (memory_append workspace_id session_id "user" text {^user_id user_id})
    (memory_append workspace_id session_id "assistant" paused_response {^run_id run_id ^paused true})
    (run_complete run_id "paused" nil)
    (log .warn #"#{run_id} skipped: paused reason=#{pause_status/pause_reason}")
    (return {^run_id run_id ^response paused_response ^steps 0 ^tool_calls 0 ^paused true ^pause_status pause_status})
  )

  # Load conversation history
  (var history (memory_recent session_id 20))
  (log .info #"Loaded #{history/.size} history entries for session #{session_id}")

  # Record user message
  (memory_append workspace_id session_id "user" text {^user_id user_id})

  (var tools_spec (build_tools_spec))
  (var step 0)
  (var tool_call_count 0)
  (var final_response "")

  (loop
    (if (step >= MAX_STEPS)
      (log .warn #"#{run_id} hit MAX_STEPS limit (#{MAX_STEPS})")
      (final_response = "Agent reached maximum step limit.")
      (break)
    )
    (step += 1)
    (log .info #"#{run_id} step #{step}/#{MAX_STEPS}")

    # Build messages and call LLM with native tools
    (var messages (build_messages history text))
    (var result (call_llm messages tools_spec))
    (var content result/content)
    (var tool_calls result/tool_calls)

    # No tool calls -> final response
    (if (tool_calls/.size == 0)
      (log .debug #"#{run_id} no tool calls - final response")
      (final_response = content)
      (break)
    )

    # Dispatch each tool call
    (if (tool_call_count >= MAX_TOOL_CALLS)
      (log .warn #"#{run_id} hit MAX_TOOL_CALLS limit (#{MAX_TOOL_CALLS})")
      (final_response = "Agent reached maximum tool call limit.")
      (break)
    )

    # Add assistant message with tool_calls to history
    (history .append {^role "assistant" ^content content ^tool_calls tool_calls})

    (tool_calls .each (fn [tc]
      (tool_call_count += 1)
      (var fn_info tc/function)
      (var tool_name fn_info/name)
      (var tool_args_str fn_info/arguments)
      (log .info #"#{run_id} dispatching tool #{tool_call_count}/#{MAX_TOOL_CALLS}: #{tool_name}")

      # Parse arguments JSON string; coerce to map for tool handlers.
      (var parsed_args (try (gene/json/parse tool_args_str) catch * nil))
      (var tool_args (if (parsed_args is Map) parsed_args else {}))
      (var tool_result (invoke_tool run_id workspace_id user_id channel_id tool_name tool_args))

      # Build result text
      (var result_text (if tool_result/ok
        tool_result/result/.to_json
      else
        #"Error: #{tool_result/error}"
      ))
      (log .debug #"#{run_id} tool result: #{result_text}")

      # Add tool result message with tool_call_id (OpenAI format)
      (history .append {^role "tool" ^tool_call_id tc/id ^content result_text})
    ))

    # Update text for next iteration context
    (text = "Continue based on the tool results above.")
  )

  # Record agent response
  (memory_append workspace_id session_id "assistant" final_response {^run_id run_id})
  (run_complete run_id "completed" nil)

  (log .info #"=== Agent run completed: #{run_id} steps=#{step} tool_calls=#{tool_call_count} response_len=#{final_response/.length} ===")

  {^run_id run_id ^response final_response ^steps step ^tool_calls tool_call_count}
)
