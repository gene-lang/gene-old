#!/usr/bin/env gene run

# GeneClaw - Tool-using Agent Platform
# Entry point: HTTP server with Slack webhook and REST API

(import CONFIG get_public_config_gene get_public_config_at_path render_public_config_value from "config")
(import init_db from "db")
(import init_tools from "tools")
(import run_agent run_agent_envelope from "agent")
(import start_scheduler from "scheduler")
(import is_paused check_pause_timeout get_pause_status start_pause_watchdog from "hotswap_state")
(import build_post_message_payload from "slack")
(import genex/http/http_post)

(var log (new genex/logging/Logger $ns))

# ============================================================
# Helpers
# ============================================================
(fn json_response [status data]
  (genex/http/respond status data/.to_json {^Content-Type "application/json"})
)

(fn gene_response [status body]
  (genex/http/respond status body/.to_s {^Content-Type "text/plain; charset=utf-8"})
)

(fn normalize_slack_attachment [file]
  (var url_private (file/url_private || ""))
  (var url_private_download (file/url_private_download || ""))
  (var download_url (url_private_download || url_private))
  {
    ^source "slack"
    ^file_id (file/id || "")
    ^filename (file/name || "")
    ^title (file/title || "")
    ^mime_type (file/mimetype || "")
    ^filetype (file/filetype || "")
    ^pretty_type (file/pretty_type || "")
    ^url_private url_private
    ^url_private_download url_private_download
    ^download_url download_url
    ^size (file/size || 0)
  }
)

(fn extract_slack_attachments [event]
  (var attachments [])
  (if (event/files is Array)
    (for file in event/files
      (attachments .append (normalize_slack_attachment file))
    )
  )
  (if (attachments/.empty? && event/file)
    (attachments .append (normalize_slack_attachment event/file))
  )
  attachments
)

(fn build_web_envelope [body]
  {
    ^workspace_id (body/workspace_id || "default")
    ^user_id (body/user_id || "anonymous")
    ^channel_id (body/channel_id || "general")
    ^thread_id (body/thread_id || body/thread_ts || "")
    ^text (body/text || "")
    ^attachments body/attachments
    ^metadata {^source "web"}
  }
)

(fn build_slack_envelope [body event]
  {
    ^workspace_id (body/team_id || "default")
    ^user_id (event/user || "unknown")
    ^channel_id (event/channel || "")
    ^thread_id (event/thread_ts || event/ts || "")
    ^text (event/text || "")
    ^attachments (extract_slack_attachments event)
    ^metadata {
      ^source "slack"
      ^event_type (event/type || "")
      ^subtype (event/subtype || "")
      ^slack_ts (event/ts || "")
    }
  }
)

(fn handle_socket_slack_command [envelope]
  (run_agent_envelope envelope)
)

(fn get_header [req name default_val]
  (req/.headers/<name> || default_val)
)

# ============================================================
# Route Handlers
# ============================================================
(fn handle_health [req]
  (log .trace "Health check")
  (check_pause_timeout)
  (var pause_status (get_pause_status))
  (if pause_status/paused
    (json_response 200 {
      ^status "paused"
      ^service "geneclaw"
      ^version "0.1.0"
      ^paused true
      ^pause_reason pause_status/pause_reason
      ^pause_age_ms pause_status/pause_age_ms
      ^pause_timeout_ms pause_status/pause_timeout_ms
    })
  else
    (json_response 200 {^status "ok" ^service "geneclaw" ^version "0.1.0" ^paused false})
  )
)

(fn handle_chat [req]
  # REST endpoint: POST /api/chat
  # Body: {"workspace_id": "...", "user_id": "...", "channel_id": "...", "text": "..."}
  (try
    (var body (gene/json/parse req/.body))
    (var envelope (build_web_envelope body))
    (var workspace_id envelope/workspace_id)
    (var user_id envelope/user_id)
    (var channel_id envelope/channel_id)
    (var thread_id envelope/thread_id)
    (var text envelope/text)
    (var attachments envelope/attachments)

    (if thread_id/.empty?
      (log .info #"Chat request workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} attachments=#{attachments/.size}")
    else
      (log .info #"Chat request workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} thread=#{thread_id} attachments=#{attachments/.size}")
    )
    (log .debug #"Chat text: #{text}")

    (if (text/.empty? && attachments/.empty?)
      (log .warn "Chat request missing text and attachments")
      (return (json_response 400 {^error "Missing text or attachments"}))
    )

    (var result (run_agent_envelope envelope))
    (log .info #"Chat response run=#{result/run_id} steps=#{result/steps} tool_calls=#{result/tool_calls}")
    (json_response 200 {
      ^ok true
      ^run_id result/run_id
      ^response result/response
      ^steps result/steps
      ^tool_calls result/tool_calls
    })
  catch *
    (log .error #"Chat handler error: #{$ex/message}")
    (json_response 500 {^error #"Agent error: #{$ex/message}"})
  )
)

(fn handle_config [req]
  # REST endpoint: GET /api/config
  (log .trace "Config export request")
  (var config_path req/.params/path/.to_s/.trim)
  (if config_path/.empty?
    (gene_response 200 (get_public_config_gene))
  else
    (var path_result (get_public_config_at_path config_path))
    (if path_result/found
      (gene_response 200 (render_public_config_value path_result/value))
    else
      (gene_response 404 {^error "Config path not found" ^path config_path})
    )
  )
)

(fn handle_slack_event [req]
  # Slack Events API webhook
  (try
    (var body (gene/json/parse req/.body))

    # URL verification challenge
    (if (body/type == "url_verification")
      (log .info "Slack URL verification challenge received")
      (return (json_response 200 {^challenge body/challenge}))
    )

    # Only handle event_callback
    (if (body/type != "event_callback")
      (log .debug #"Ignoring Slack event type: #{body/type}")
      (return (json_response 200 {^ok true}))
    )

    (var event body/event)
    (if_not event
      (log .debug "Slack event_callback with no event payload")
      (return (json_response 200 {^ok true}))
    )

    # Ignore bot messages
    (if event/bot_id
      (log .trace #"Ignoring bot message from bot_id=#{event/bot_id}")
      (return (json_response 200 {^ok true}))
    )
    (if (event/subtype == "bot_message")
      (log .trace "Ignoring bot_message subtype")
      (return (json_response 200 {^ok true}))
    )

    (var envelope (build_slack_envelope body event))
    (var workspace_id envelope/workspace_id)
    (var user_id envelope/user_id)
    (var channel_id envelope/channel_id)
    (var thread_id envelope/thread_id)
    (var text envelope/text)
    (var attachments envelope/attachments)

    (if (channel_id/.empty? || (text/.empty? && (attachments/.size == 0)))
      (log .debug "Slack event missing channel or message content - skipping")
      (return (json_response 200 {^ok true}))
    )

    (if thread_id/.empty?
      (log .info #"Slack event workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} attachments=#{attachments/.size}")
    else
      (log .info #"Slack event workspace=#{workspace_id} user=#{user_id} channel=#{channel_id} thread=#{thread_id} attachments=#{attachments/.size}")
    )
    (log .debug #"Slack text: #{text}")

    # Run agent
    (var result (run_agent_envelope envelope))
    (log .info #"Slack agent done run=#{result/run_id} steps=#{result/steps}")

    # Reply to Slack
    (if (CONFIG/slack/bot_token && result/response && result/response/.not_empty?)
      (var reply_payload (build_post_message_payload channel_id result/response thread_id))
      (try
        (log .debug #"Posting Slack reply to channel=#{channel_id}")
        (await (http_post "https://slack.com/api/chat.postMessage"
          reply_payload/.to_json
          {
            ^Content-Type "application/json; charset=utf-8"
            ^Authorization #"Bearer #{CONFIG/slack/bot_token}"}))
        (log .info "Slack reply sent successfully")
      catch *
        (log .error #"Slack reply failed: #{$ex/message}")
      )
    )

    (json_response 200 {^ok true})
  catch *
    (log .error #"Slack event handler error: #{$ex/message}")
    (json_response 200 {^ok true})
  )
)

# ============================================================
# Router
# ============================================================
(fn handle_request [req]
  (var path req/.path)
  (var method req/.method)
  (log .info #"#{method} #{path}")

  (check_pause_timeout)
  (if ((path != "/health") && (is_paused))
    (log .warn #"Request rejected while paused: #{method} #{path}")
    (var pause_status (get_pause_status))
    (json_response 503 {
      ^status "paused"
      ^message "Upgrading"
      ^pause_reason pause_status/pause_reason
      ^pause_age_ms pause_status/pause_age_ms
      ^pause_timeout_ms pause_status/pause_timeout_ms
    })
  elif (path == "/health")
    (handle_health req)
  elif ((path == "/api/config") && (method == "GET"))
    (handle_config req)
  elif ((path == "/api/chat") && (method == "POST"))
    (handle_chat req)
  elif ((path == "/slack/events") && (method == "POST"))
    (handle_slack_event req)
  else
    (log .warn #"404 Not found: #{method} #{path}")
    (json_response 404 {^error "Not found"})
  )
)

# ============================================================
# Startup
# ============================================================
(log .info "=== GeneClaw Agent Platform ===")
(init_db)
(init_tools)
(start_pause_watchdog)
(start_scheduler)

(if CONFIG/slack/app_token
  # Socket Mode: connect to Slack via outbound WebSocket (no public URL needed)
  (log .info #"Starting Slack Socket Mode on http://localhost:#{CONFIG/port}")
  (log .info "Endpoints: GET /health, GET /api/config, POST /api/chat, POST /slack/events (disabled)")
  (genex/http/start_server CONFIG/port handle_request)
  (genex/ai/start_slack_socket_mode CONFIG/slack/app_token CONFIG/slack/bot_token handle_socket_slack_command)
else
  # Webhook mode: Slack sends events via HTTP POST
  (log .info #"Starting server on http://localhost:#{CONFIG/port}")
  (log .info "Endpoints: GET /health, GET /api/config, POST /api/chat, POST /slack/events")
  (genex/http/start_server CONFIG/port handle_request)
)
(run_forever)
