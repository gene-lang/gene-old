# GeneClaw Configuration
# Environment variables and application settings

(var $ns/log (new genex/logging/Logger $ns))

($ns/PORT = (($env/PORT || "4090") .to_i))
($ns/DB_PATH = "geneclaw.sqlite")
# openai | anthropic
($ns/LLM_PROVIDER = (($env/GENECLAW_LLM_PROVIDER || "openai") .to_s; .to_lower))
($ns/OPENAI_API_KEY = ($env/OPENAI_API_KEY || ""))
($ns/OPENAI_MODEL = ($env/OPENAI_MODEL || "gpt-5-mini"))
($ns/OPENAI_BASE_URL = ($env/OPENAI_BASE_URL || $env/OPENAI_API_BASE || ""))
($ns/OPENAI_TIMEOUT_MS = (($env/OPENAI_TIMEOUT_MS || "60000") .to_i))
($ns/ANTHROPIC_API_KEY = ($env/ANTHROPIC_API_KEY || ""))
($ns/ANTHROPIC_AUTH_TOKEN = ($env/ANTHROPIC_AUTH_TOKEN || $env/ANTHROPIC_OAUTH_TOKEN || ""))
($ns/ANTHROPIC_MODEL = ($env/ANTHROPIC_MODEL || "claude-sonnet-4-6"))
($ns/ANTHROPIC_BASE_URL = ($env/ANTHROPIC_BASE_URL || ""))
($ns/ANTHROPIC_TIMEOUT_MS = (($env/ANTHROPIC_TIMEOUT_MS || "60000") .to_i))
($ns/SLACK_SIGNING_SECRET = $env/SLACK_SIGNING_SECRET)
($ns/SLACK_BOT_TOKEN = $env/SLACK_BOT_TOKEN)
($ns/SLACK_APP_TOKEN = $env/SLACK_APP_TOKEN)
($ns/BRAVE_API_KEY = $env/BRAVE_API_KEY)
($ns/SLACK_AGENTX_TOKEN = $env/SLACK_AGENTX_TOKEN)
($ns/MAX_STEPS = 16)
($ns/MAX_TOOL_CALLS = 8)

# Workspace root for filesystem tool
($ns/WORKSPACE_ROOT = ($env/GENECLAW_WORKSPACE || #"#{$env/HOME}/.geneclaw"))
($ns/DOCUMENT_ROOT = ($env/GENECLAW_DOCUMENT_ROOT || #"#{WORKSPACE_ROOT}/documents"))
($ns/ARTIFACT_ROOT = ($env/GENECLAW_ARTIFACT_ROOT || #"#{WORKSPACE_ROOT}/artifacts"))
($ns/DOCUMENT_MAX_UPLOAD_BYTES = (($env/GENECLAW_DOCUMENT_MAX_UPLOAD_BYTES || "10485760") .to_i))
($ns/DOCUMENT_MAX_INLINE_CHARS = (($env/GENECLAW_DOCUMENT_MAX_INLINE_CHARS || "4000") .to_i))
($ns/IMAGE_MAX_COUNT = (($env/GENECLAW_IMAGE_MAX_COUNT || "4") .to_i))

# Scheduler tick interval
($ns/SCHEDULER_TICK_MS = (($env/GENECLAW_SCHEDULER_TICK_MS || "30000") .to_i))

# Hot-swap controls
($ns/PAUSE_TIMEOUT_MS = (($env/GENECLAW_PAUSE_TIMEOUT_MS || "120000") .to_i))
($ns/PAUSE_CHECK_INTERVAL_MS = (($env/GENECLAW_PAUSE_CHECK_INTERVAL_MS || "5000") .to_i))
($ns/UPGRADE_HEALTH_ATTEMPTS = (($env/GENECLAW_UPGRADE_HEALTH_ATTEMPTS || "15") .to_i))
($ns/UPGRADE_HEALTH_INTERVAL_MS = (($env/GENECLAW_UPGRADE_HEALTH_INTERVAL_MS || "2000") .to_i))

($ns/HIDDEN_SECRET = "hidden")

(fn $ns/secret_configured [value]
  (if value
    (if ((value .to_s) .empty)
      false
    else
      true
    )
  else
    false
  )
)

(fn $ns/redact_secret [value]
  HIDDEN_SECRET
)

(fn $ns/render_public_config_value [value]
  (if (value is String)
    (gene/json/stringify value)
  else
    (value .to_s)
  )
)

(fn $ns/get_public_config []
  {
    ^port PORT
    ^db_path DB_PATH
    ^llm {
      ^provider LLM_PROVIDER
      ^max_steps MAX_STEPS
      ^max_tool_calls MAX_TOOL_CALLS
      ^openai {
        ^api_key (redact_secret OPENAI_API_KEY)
        ^api_key_configured (secret_configured OPENAI_API_KEY)
        ^model OPENAI_MODEL
        ^base_url OPENAI_BASE_URL
        ^timeout_ms OPENAI_TIMEOUT_MS
      }
      ^anthropic {
        ^api_key (redact_secret ANTHROPIC_API_KEY)
        ^api_key_configured (secret_configured ANTHROPIC_API_KEY)
        ^auth_token (redact_secret ANTHROPIC_AUTH_TOKEN)
        ^auth_token_configured (secret_configured ANTHROPIC_AUTH_TOKEN)
        ^model ANTHROPIC_MODEL
        ^base_url ANTHROPIC_BASE_URL
        ^timeout_ms ANTHROPIC_TIMEOUT_MS
      }
    }
    ^slack {
      ^signing_secret (redact_secret SLACK_SIGNING_SECRET)
      ^signing_secret_configured (secret_configured SLACK_SIGNING_SECRET)
      ^bot_token (redact_secret SLACK_BOT_TOKEN)
      ^bot_token_configured (secret_configured SLACK_BOT_TOKEN)
      ^app_token (redact_secret SLACK_APP_TOKEN)
      ^app_token_configured (secret_configured SLACK_APP_TOKEN)
      ^agentx_token (redact_secret SLACK_AGENTX_TOKEN)
      ^agentx_token_configured (secret_configured SLACK_AGENTX_TOKEN)
    }
    ^search {
      ^brave_api_key (redact_secret BRAVE_API_KEY)
      ^brave_api_key_configured (secret_configured BRAVE_API_KEY)
    }
    ^workspace {
      ^root WORKSPACE_ROOT
      ^document_root DOCUMENT_ROOT
      ^artifact_root ARTIFACT_ROOT
    }
    ^documents {
      ^max_upload_bytes DOCUMENT_MAX_UPLOAD_BYTES
      ^max_inline_chars DOCUMENT_MAX_INLINE_CHARS
      ^max_image_count IMAGE_MAX_COUNT
    }
    ^scheduler {
      ^tick_ms SCHEDULER_TICK_MS
    }
    ^hotswap {
      ^pause_timeout_ms PAUSE_TIMEOUT_MS
      ^pause_check_interval_ms PAUSE_CHECK_INTERVAL_MS
      ^upgrade_health_attempts UPGRADE_HEALTH_ATTEMPTS
      ^upgrade_health_interval_ms UPGRADE_HEALTH_INTERVAL_MS
    }
  }
)

(fn $ns/get_public_config_at_path [path]
  (var current (get_public_config))
  (var found true)
  (var normalized_parts [])

  (for part in ((path || "") .split "/")
    (var key (part .trim))
    (if_not key/.empty
      (normalized_parts .add key)
    )
  )

  (for key in normalized_parts
    (if (current is Map)
      (if (current .contains key)
        (current = (current .get key))
      else
        (found = false)
        (break)
      )
    else
      (found = false)
      (break)
    )
  )

  {^found found ^value current}
)

(fn $ns/get_public_config_gene []
  (render_public_config_value (get_public_config))
)

(fn $ns/get_public_config_gene_at_path [path]
  (var result (get_public_config_at_path path))
  (if result/found
    (render_public_config_value result/value)
  else
    nil
  )
)

# Log loaded configuration (redact secrets)
(log .info #"PORT=#{PORT} DB_PATH=#{DB_PATH} LLM_PROVIDER=#{LLM_PROVIDER}")
(log .info #"MAX_STEPS=#{MAX_STEPS} MAX_TOOL_CALLS=#{MAX_TOOL_CALLS} SCHEDULER_TICK_MS=#{SCHEDULER_TICK_MS}")
(log .info #"OPENAI_MODEL=#{OPENAI_MODEL} OPENAI_TIMEOUT_MS=#{OPENAI_TIMEOUT_MS}")
(log .info #"ANTHROPIC_MODEL=#{ANTHROPIC_MODEL} ANTHROPIC_TIMEOUT_MS=#{ANTHROPIC_TIMEOUT_MS}")
(log .info #"WORKSPACE_ROOT=#{WORKSPACE_ROOT}")
(log .info #"DOCUMENT_ROOT=#{DOCUMENT_ROOT} ARTIFACT_ROOT=#{ARTIFACT_ROOT}")
(log .info #"DOCUMENT_MAX_UPLOAD_BYTES=#{DOCUMENT_MAX_UPLOAD_BYTES} DOCUMENT_MAX_INLINE_CHARS=#{DOCUMENT_MAX_INLINE_CHARS} IMAGE_MAX_COUNT=#{IMAGE_MAX_COUNT}")
(log .info #"PAUSE_TIMEOUT_MS=#{PAUSE_TIMEOUT_MS} PAUSE_CHECK_INTERVAL_MS=#{PAUSE_CHECK_INTERVAL_MS}")
(log .info #"UPGRADE_HEALTH_ATTEMPTS=#{UPGRADE_HEALTH_ATTEMPTS} UPGRADE_HEALTH_INTERVAL_MS=#{UPGRADE_HEALTH_INTERVAL_MS}")
(if OPENAI_BASE_URL/.empty
  (log .info "OPENAI_BASE_URL not set; using client default")
else
  (log .info #"OPENAI_BASE_URL=#{OPENAI_BASE_URL}")
)
(if ANTHROPIC_BASE_URL/.empty
  (log .info "ANTHROPIC_BASE_URL not set; using client default")
else
  (log .info #"ANTHROPIC_BASE_URL=#{ANTHROPIC_BASE_URL}")
)
(if (OPENAI_API_KEY/.empty == false)
  (log .info "OPENAI_API_KEY is set")
else
  (log .warn "OPENAI_API_KEY not set - will run in mock mode")
)
(if (ANTHROPIC_AUTH_TOKEN/.empty == false)
  (log .info "ANTHROPIC_AUTH_TOKEN is set")
elif (ANTHROPIC_API_KEY/.empty == false)
  (log .info "ANTHROPIC_API_KEY is set")
else
  (log .warn "Anthropic credentials not set - Anthropic provider will run in mock mode")
)
(if SLACK_APP_TOKEN
  (log .info "Slack Socket Mode enabled")
elif SLACK_BOT_TOKEN
  (log .info "Slack Webhook Mode enabled")
else
  (log .debug "Slack integration not configured")
)
