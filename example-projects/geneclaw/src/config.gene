# GeneClaw configuration
# Resolves config from schema + env, exports a single CONFIG map.
# Consumers access values via paths: CONFIG/llm/provider, CONFIG/slack/bot_token, etc.

(import GENECLAW_HOME HOME_CONFIG_PATH HOME_STATE_PATH HOME_WORKSPACE_PATH SESSIONS_PATH SCHEDULER_PATH JOBS_PATH RUNS_PATH ASSETS_ROOT FILES_ROOT DOCUMENT_ROOT ARTIFACT_ROOT LOGS_PATH ARCHIVE_PATH TMP_PATH ensure_home_bootstrap load_home_config_raw interpolate_value from "home_store")
(import CONFIG_SCHEMA from "config_schema")
(import ensure_map lookup_path set_path_value resolve_config_from_schema build_public_config_from_schema secret_configured:helper_secret_configured redact_secret:helper_redact_secret render_public_config_value:helper_render_public_config_value from "config_helpers")

(var $ns/log (new genex/logging/Logger $ns))

(ensure_home_bootstrap)

(var RAW_HOME_CONFIG (load_home_config_raw))
(var HOME_CONFIG (ensure_map (interpolate_value RAW_HOME_CONFIG)))
(var EFFECTIVE_CONFIG (resolve_config_from_schema CONFIG_SCHEMA HOME_CONFIG ^env $env))

# ── Canonical config export ───────────────────────────────────
# All resolved config values live here. Access via path:
#   CONFIG/port
#   CONFIG/llm/provider
#   CONFIG/llm/openai/api_key
#   CONFIG/slack/bot_token
#   CONFIG/documents/max_upload_bytes
($ns/CONFIG = EFFECTIVE_CONFIG)

# Keep scalar exports for compatibility while treating CONFIG as the
# canonical source of truth for new code.
($ns/PORT = EFFECTIVE_CONFIG/port)

($ns/LLM_PROVIDER = EFFECTIVE_CONFIG/llm/provider)
($ns/THINKING_LEVEL = EFFECTIVE_CONFIG/llm/thinking_level)
($ns/CONTEXT_SIZE = EFFECTIVE_CONFIG/llm/context_size)
($ns/MAX_STEPS = EFFECTIVE_CONFIG/llm/max_steps)
($ns/MAX_TOOL_CALLS = EFFECTIVE_CONFIG/llm/max_tool_calls)

($ns/OPENAI_API_KEY = EFFECTIVE_CONFIG/llm/openai/api_key)
($ns/OPENAI_MODEL = EFFECTIVE_CONFIG/llm/openai/model)
($ns/OPENAI_BASE_URL = EFFECTIVE_CONFIG/llm/openai/base_url)
($ns/OPENAI_TIMEOUT_MS = EFFECTIVE_CONFIG/llm/openai/timeout_ms)

($ns/ANTHROPIC_API_KEY = EFFECTIVE_CONFIG/llm/anthropic/api_key)
($ns/ANTHROPIC_AUTH_TOKEN = EFFECTIVE_CONFIG/llm/anthropic/auth_token)
($ns/ANTHROPIC_MODEL = EFFECTIVE_CONFIG/llm/anthropic/model)
($ns/ANTHROPIC_BASE_URL = EFFECTIVE_CONFIG/llm/anthropic/base_url)
($ns/ANTHROPIC_TIMEOUT_MS = EFFECTIVE_CONFIG/llm/anthropic/timeout_ms)

($ns/SLACK_SIGNING_SECRET = EFFECTIVE_CONFIG/slack/signing_secret)
($ns/SLACK_BOT_TOKEN = EFFECTIVE_CONFIG/slack/bot_token)
($ns/SLACK_APP_TOKEN = EFFECTIVE_CONFIG/slack/app_token)
($ns/SLACK_AGENTX_TOKEN = EFFECTIVE_CONFIG/slack/agentx_token)
($ns/BRAVE_API_KEY = EFFECTIVE_CONFIG/search/brave_api_key)

($ns/DOCUMENT_MAX_UPLOAD_BYTES = EFFECTIVE_CONFIG/documents/max_upload_bytes)
($ns/DOCUMENT_MAX_INLINE_CHARS = EFFECTIVE_CONFIG/documents/max_inline_chars)
($ns/IMAGE_MAX_COUNT = EFFECTIVE_CONFIG/documents/max_image_count)

($ns/SCHEDULER_TICK_MS = EFFECTIVE_CONFIG/scheduler/tick_ms)

($ns/PAUSE_TIMEOUT_MS = EFFECTIVE_CONFIG/hotswap/pause_timeout_ms)
($ns/PAUSE_CHECK_INTERVAL_MS = EFFECTIVE_CONFIG/hotswap/pause_check_interval_ms)
($ns/UPGRADE_HEALTH_ATTEMPTS = EFFECTIVE_CONFIG/hotswap/upgrade_health_attempts)
($ns/UPGRADE_HEALTH_INTERVAL_MS = EFFECTIVE_CONFIG/hotswap/upgrade_health_interval_ms)

# ── Directory paths (from home_store) ─────────────────────────
# These are filesystem layout, not user config — kept as named exports.
($ns/GENECLAW_HOME = GENECLAW_HOME)
($ns/HOME_CONFIG_PATH = HOME_CONFIG_PATH)
($ns/HOME_STATE_PATH = HOME_STATE_PATH)
($ns/HOME_WORKSPACE_PATH = HOME_WORKSPACE_PATH)
($ns/SESSIONS_PATH = SESSIONS_PATH)
($ns/SCHEDULER_PATH = SCHEDULER_PATH)
($ns/JOBS_PATH = JOBS_PATH)
($ns/RUNS_PATH = RUNS_PATH)
($ns/ASSETS_ROOT = ASSETS_ROOT)
($ns/LOGS_PATH = LOGS_PATH)
($ns/ARCHIVE_PATH = ARCHIVE_PATH)
($ns/TMP_PATH = TMP_PATH)
($ns/WORKSPACE_ROOT = FILES_ROOT)
($ns/DOCUMENT_ROOT = DOCUMENT_ROOT)
($ns/ARTIFACT_ROOT = ARTIFACT_ROOT)

# ── Public config helpers ─────────────────────────────────────

(fn $ns/secret_configured [value]
  (helper_secret_configured value)
)

(fn $ns/redact_secret [value]
  (helper_redact_secret value)
)

(fn $ns/render_public_config_value [value]
  (helper_render_public_config_value value)
)

(fn build_runtime_public_config []
  (var public_config (build_public_config_from_schema CONFIG_SCHEMA EFFECTIVE_CONFIG))
  (set_path_value public_config "home/root" GENECLAW_HOME)
  (set_path_value public_config "home/config_root" HOME_CONFIG_PATH)
  (set_path_value public_config "home/state_root" HOME_STATE_PATH)
  (set_path_value public_config "home/sessions_root" SESSIONS_PATH)
  (set_path_value public_config "home/scheduler_root" SCHEDULER_PATH)
  (set_path_value public_config "home/jobs_root" JOBS_PATH)
  (set_path_value public_config "home/runs_root" RUNS_PATH)
  (set_path_value public_config "home/assets_root" ASSETS_ROOT)
  (set_path_value public_config "home/logs_root" LOGS_PATH)
  (set_path_value public_config "home/archive_root" ARCHIVE_PATH)
  (set_path_value public_config "home/tmp_root" TMP_PATH)
  (set_path_value public_config "workspace/state_root" HOME_STATE_PATH)
  (set_path_value public_config "workspace/root" FILES_ROOT)
  (set_path_value public_config "workspace/document_root" DOCUMENT_ROOT)
  (set_path_value public_config "workspace/artifact_root" ARTIFACT_ROOT)
  (set_path_value public_config "assets/uploaded_root" DOCUMENT_ROOT)
  (set_path_value public_config "assets/generated_root" ARTIFACT_ROOT)
  public_config
)

(fn $ns/get_public_config []
  (build_runtime_public_config)
)

(fn $ns/get_public_config_at_path [path]
  (lookup_path (get_public_config) path)
)

(fn $ns/get_public_config_gene []
  (render_public_config_value (get_public_config))
)

(fn $ns/get_public_config_gene_at_path [path]
  (var result (get_public_config_at_path path))
  (if result/found
    (render_public_config_value result/value)
  else
    nil
  )
)

# ── Startup logging ───────────────────────────────────────────
(log .info #"HOME root=#{GENECLAW_HOME} config=#{HOME_CONFIG_PATH} state=#{HOME_STATE_PATH} sessions=#{SESSIONS_PATH} tmp=#{TMP_PATH}")
(log .info #"LLM provider=#{CONFIG/llm/provider} thinking=#{CONFIG/llm/thinking_level} context=#{CONFIG/llm/context_size} steps=#{CONFIG/llm/max_steps} tool_calls=#{CONFIG/llm/max_tool_calls}")
(log .info #"OpenAI model=#{CONFIG/llm/openai/model} timeout_ms=#{CONFIG/llm/openai/timeout_ms} configured=#{(secret_configured CONFIG/llm/openai/api_key)}")
(log .info #"Anthropic model=#{CONFIG/llm/anthropic/model} timeout_ms=#{CONFIG/llm/anthropic/timeout_ms} configured=#{((secret_configured CONFIG/llm/anthropic/api_key) || (secret_configured CONFIG/llm/anthropic/auth_token))}")
(log .info #"Documents upload_bytes=#{CONFIG/documents/max_upload_bytes} inline_chars=#{CONFIG/documents/max_inline_chars} image_max=#{CONFIG/documents/max_image_count}")
(log .info #"Scheduler tick_ms=#{CONFIG/scheduler/tick_ms} hotswap pause_timeout_ms=#{CONFIG/hotswap/pause_timeout_ms} pause_check_interval_ms=#{CONFIG/hotswap/pause_check_interval_ms}")
(if CONFIG/slack/app_token/.empty?
  (if CONFIG/slack/bot_token/.empty?
    (log .debug "Slack integration not configured")
  else
    (log .info "Slack Webhook Mode enabled")
  )
else
  (log .info "Slack Socket Mode enabled")
)
