# GeneClaw LLM provider adapters
# Translates the internal agent format to provider-specific request/response shapes.

(import CONFIG from "config")
(import ensure_array ensure_map from "config_helpers")
(import get_system_prompt from "workspace_state")

(var log (new genex/logging/Logger $ns))

(fn parse_tool_arguments [args_json]
  (var parsed (try (gene/json/parse (args_json || "{}")) catch * nil))
  (ifel (parsed is Map) parsed {})
)

(fn supported_image_mime? [mime_type]
  ([
    "image/png"
    "image/jpeg"
    "image/jpg"
    "image/gif"
    "image/webp"
  ] .contains mime_type/.to_s/.to_lower)
)

(fn $ns/provider_supports_images? [provider = nil]
  (var p (provider || CONFIG/llm/provider))
  (["openai" "anthropic"] .contains p/.to_s/.to_lower)
)

(fn image_attachment_error [image_attachments provider = nil]
  (var images (ensure_array image_attachments))
  (var selected_provider (((provider || CONFIG/llm/provider) .to_s) .to_lower))
  (if images/.empty?
    (return "")
  )

  (if_not (provider_supports_images? selected_provider)
    (return #"The current model provider (#{selected_provider}) does not support image inputs.")
  )

  (if (images/.size > CONFIG/documents/max_image_count)
    (return #"This request includes #{images/.size} images, but the current limit is #{CONFIG/documents/max_image_count}.")
  )

  (for image in images
    (if image/local_path/.empty?
      (return #"Image attachment #{(image/filename || image/document_id || "unknown")} is missing a local file path.")
    )
    (if_not (supported_image_mime? image/mime_type)
      (return #"Unsupported image type for #{(image/filename || image/document_id || "unknown")}: #{(image/mime_type || "unknown")}")
    )
    (if (((image/byte_size || 0) > 0) && ((image/byte_size || 0) > CONFIG/documents/max_upload_bytes))
      (return #"Image attachment #{(image/filename || image/document_id || "unknown")} exceeds #{CONFIG/documents/max_upload_bytes} bytes.")
    )
  )

  ""
)

(fn $ns/validate_image_inputs [image_attachments provider = nil]
  (var error (image_attachment_error image_attachments provider))
  (if error/.empty?
    {^ok true ^error ""}
  else
    {^ok false ^error error}
  )
)

(fn read_image_base64 [image]
  (var existing (image/base64_data || ""))
  (if existing/.not_empty?
    (return existing)
  )
  (var encoded (genex/ai/documents/file_to_base64 image/local_path))
  (image/base64_data = encoded)
  encoded
)

(fn openai_image_part [image]
  {^type "image_url"
   ^image_url {
     ^url #"data:#{image/mime_type};base64,#{(read_image_base64 image)}"
     ^detail "auto"
   }}
)

(fn openai_responses_image_part [image]
  {^type "input_image"
   ^source {
     ^type "base64"
     ^media_type image/mime_type
     ^data (read_image_base64 image)
   }}
)

(fn anthropic_image_block [image]
  {^type "image"
   ^source {
     ^type "base64"
     ^media_type image/mime_type
     ^data (read_image_base64 image)
   }}
)

(fn build_openai_user_content [user_text image_attachments]
  (var images (ensure_array image_attachments))
  (if images/.empty?
    (return user_text)
  )

  (var content [])
  (if user_text/.not_empty?
    (content .append {^type "text" ^text user_text})
  )
  (images .each (fn [image]
    (content .append (openai_image_part image))
  ))
  content
)

(fn build_openai_responses_user_content [user_text image_attachments]
  (var images (ensure_array image_attachments))
  (if images/.empty?
    (return user_text)
  )

  (var content [])
  (if user_text/.not_empty?
    (content .append {^type "input_text" ^text user_text})
  )
  (images .each (fn [image]
    (content .append (openai_responses_image_part image))
  ))
  content
)

(fn build_anthropic_user_blocks [user_text image_attachments]
  (var blocks [])
  (var images (ensure_array image_attachments))
  (if user_text/.not_empty?
    (blocks .append {^type "text" ^text user_text})
  )
  (images .each (fn [image]
    (blocks .append (anthropic_image_block image))
  ))
  blocks
)

(fn openai_message_log_text [msg]
  (var content (msg/content || ""))
  (if (content is Array)
    (var parts [])
    (content .each (fn [part]
      (if ((part is Map) && ((part/type == "text") || (part/type == "input_text") || (part/type == "output_text")))
        (parts .append #"{type:text,text=#{(part/text || "")}}")
      elif ((part is Map) && (part/type == "image_url"))
        (parts .append #"{type:image_url,url=[image data omitted]}")
      elif ((part is Map) && (part/type == "input_image"))
        (parts .append #"{type:input_image,source=[image data omitted]}")
      else
        (parts .append #"{type=#{(part/type || "unknown")}}")
      )
    ))
    #"{role=#{msg/role}, content=[#{(parts .join ", ")}]}"
  else
    (msg .to_json)
  )
)

(fn anthropic_message_log_text [msg]
  (var content (msg/content || []))
  (if (content is Array)
    (var parts [])
    (content .each (fn [block]
      (if ((block is Map) && (block/type == "text"))
        (parts .append #"{type:text,text=#{(block/text || "")}}")
      elif ((block is Map) && (block/type == "image"))
        (parts .append #"{type:image,source=[image data omitted]}")
      elif ((block is Map) && (block/type == "tool_result"))
        (parts .append #"{type:tool_result,tool_use_id=#{(block/tool_use_id || "")}}")
      elif ((block is Map) && (block/type == "tool_use"))
        (parts .append #"{type:tool_use,name=#{(block/name || "")}}")
      else
        (parts .append #"{type=#{(block/type || "unknown")}}")
      )
    ))
    #"{role=#{msg/role}, content=[#{(parts .join ", ")}]}"
  else
    (msg .to_json)
  )
)

(fn log_openai_messages [messages history]
  (log .info #"Built OpenAI request messages=#{messages/.size} (#{history/.size} history + system + user)")
  (var msg_idx 0)
  (messages .each (fn [msg]
    (log .info #"--- Message #{msg_idx} [#{msg/role}] ---")
    (log .info (openai_message_log_text msg))
    (msg_idx += 1)
  ))
  (log .info "--- End of messages ---")
)

(fn openai_input_item_log_text [item]
  (var item_type (item/type || ""))
  (if (item_type == "message")
    (return (openai_message_log_text item))
  )
  (if (item_type == "function_call")
    (return #"{type:function_call,call_id=#{(item/call_id || "")},name=#{(item/name || "")},arguments=#{(item/arguments || "{}")}}")
  )
  (if (item_type == "function_call_output")
    (return #"{type:function_call_output,call_id=#{(item/call_id || "")},output=#{(item/output || "")}}")
  )
  (item .to_json)
)

(fn log_openai_codex_request [request history]
  (log .info #"Built OpenAI Codex request input=#{request/input/.size} tools=#{request/tools/.size} (#{history/.size} history + current user, system separate)")
  (log .info "--- Instructions ---")
  (log .info request/instructions)
  (var item_idx 0)
  (request/input .each (fn [item]
    (log .info #"--- Input #{item_idx} [#{(item/type || "unknown")}] ---")
    (log .info (openai_input_item_log_text item))
    (item_idx += 1)
  ))
  (log .info "--- End of input ---")
)

(fn log_anthropic_request [request history]
  (log .info #"Built Anthropic request messages=#{request/messages/.size} tools=#{request/tools/.size} (#{history/.size} history + user, system separate)")
  (log .info "--- System ---")
  (log .info request/system)
  (var msg_idx 0)
  (request/messages .each (fn [msg]
    (log .info #"--- Message #{msg_idx} [#{msg/role}] ---")
    (log .info (anthropic_message_log_text msg))
    (msg_idx += 1)
  ))
  (log .info "--- End of messages ---")
)

(fn $ns/build_openai_request [history user_text tools_spec image_attachments = []]
  (var messages [])
  (messages .append {^role "system" ^content get_system_prompt/.call})

  (history .each (fn [entry]
    (var msg {^role entry/role ^content (entry/content || "")})
    (if (entry/role == "assistant")
      (if entry/tool_calls
        (msg .set "tool_calls" entry/tool_calls)
      )
    elif (entry/role == "tool")
      (if entry/tool_call_id
        (msg .set "tool_call_id" entry/tool_call_id)
      )
    )
    (messages .append msg)
  ))

  (messages .append {^role "user" ^content (build_openai_user_content user_text image_attachments)})
  (log_openai_messages messages history)
  {^messages messages ^tools tools_spec}
)

(fn history_content_to_openai_responses [content]
  (if (content is Array)
    (var parts [])
    (content .each (fn [part]
      (if ((part is Map) && ((part/type == "text") || (part/type == "input_text") || (part/type == "output_text")))
        (parts .append {^type "input_text" ^text (part/text || "")})
      elif ((part is Map) && (part/type == "image_url"))
        (parts .append {^type "input_image" ^source {^type "url" ^url (((part/image_url || {})/url) || "")}})
      elif ((part is Map) && (part/type == "input_image"))
        (parts .append part)
      )
    ))
    (if ((parts/.size == 1) && (parts/0/type == "input_text"))
      (return (parts/0/text || ""))
    )
    parts
  else
    (content || "")
  )
)

(fn openai_codex_function_call_from_history [tool_call]
  (var fn_info (ensure_map (tool_call/function || {})))
  {^type "function_call"
   ^call_id (tool_call/id || "")
   ^name (fn_info/name || "")
   ^arguments (fn_info/arguments || "{}")}
)

(fn openai_codex_tool_output_from_history [entry]
  {^type "function_call_output"
   ^call_id (entry/tool_call_id || "")
   ^output (entry/content || "")}
)

(fn build_openai_codex_input [history user_text image_attachments]
  (var input [])

  (history .each (fn [entry]
    (if (entry/role == "assistant")
      (var assistant_content (history_content_to_openai_responses (entry/content || "")))
      (if (if (assistant_content is String) assistant_content/.not_empty? else ((ensure_array assistant_content)/.size > 0))
        (input .append {^type "message" ^role "assistant" ^content assistant_content})
      )
      ((ensure_array (entry/tool_calls || [])) .each (fn [tool_call]
        (var call_item (openai_codex_function_call_from_history tool_call))
        (if call_item/call_id/.not_empty?
          (input .append call_item)
        )
      ))
    elif (entry/role == "tool")
      (var call_id (entry/tool_call_id || ""))
      (if call_id/.not_empty?
        (input .append (openai_codex_tool_output_from_history entry))
      )
    elif (entry/role == "user")
      (var history_content (history_content_to_openai_responses (entry/content || "")))
      (if (if (history_content is String) history_content/.not_empty? else ((ensure_array history_content)/.size > 0))
        (input .append {^type "message" ^role "user" ^content history_content})
      )
    )
  ))

  (var current_content (build_openai_responses_user_content user_text image_attachments))
  (if (if (current_content is String) current_content/.not_empty? else ((ensure_array current_content)/.size > 0))
    (input .append {^type "message" ^role "user" ^content current_content})
  )

  input
)

(fn openai_codex_tool_from_openai [tool_spec]
  (var fn_def (ensure_map (tool_spec/function || {})))
  {^type (tool_spec/type || "function")
   ^name (fn_def/name || "")
   ^description (fn_def/description || "")
   ^parameters (fn_def/parameters || {^type "object" ^properties {} ^required []})}
)

(fn $ns/build_openai_codex_request [history user_text tools_spec image_attachments = []]
  (var tools [])
  (tools_spec .each (fn [tool_spec]
    (tools .append (openai_codex_tool_from_openai tool_spec))
  ))
  (var request {
    ^instructions get_system_prompt/.call
    ^input (build_openai_codex_input history user_text image_attachments)
    ^tools tools
  })
  (log_openai_codex_request request history)
  request
)

(fn anthropic_tool_from_openai [tool_spec]
  (var fn_def (ensure_map (tool_spec/function || {})))
  {^name (fn_def/name || "")
   ^description (fn_def/description || "")
   ^input_schema (fn_def/parameters || {^type "object" ^properties {} ^required []})}
)

(fn anthropic_tool_use_from_call [tool_call]
  (var fn_info (ensure_map (tool_call/function || {})))
  {^type "tool_use"
   ^id (tool_call/id || "")
   ^name (fn_info/name || "")
   ^input (parse_tool_arguments (fn_info/arguments || "{}"))}
)

(fn anthropic_tool_result_from_history [entry]
  (var result {^type "tool_result"
               ^tool_use_id (entry/tool_call_id || "")
               ^content (entry/content || "")})
  (if (entry/is_error == true)
    (result .set "is_error" true)
  )
  result
)

(fn build_anthropic_messages [history user_text image_attachments]
  (var messages [])
  (var pending_tool_results [])

  (history .each (fn [entry]
    (if (entry/role == "tool")
      (var tool_use_id (entry/tool_call_id || ""))
      (if tool_use_id/.not_empty?
        (pending_tool_results .append (anthropic_tool_result_from_history entry))
      )
    else
      (if (pending_tool_results/.size > 0)
        (messages .append {^role "user" ^content pending_tool_results})
        (pending_tool_results = [])
      )

      (var blocks [])
      (var text (entry/content || ""))
      (if text/.not_empty?
        (blocks .append {^type "text" ^text text})
      )

      (if (entry/role == "assistant")
        (var entry_tool_calls (ensure_array (entry/tool_calls || [])))
        (entry_tool_calls .each (fn [tool_call]
          (blocks .append (anthropic_tool_use_from_call tool_call))
        ))
      )

      (if blocks/.not_empty?
        (messages .append {^role entry/role ^content blocks})
      )
    )
  ))

  (if pending_tool_results/.not_empty?
    (var final_blocks [])
    (pending_tool_results .each (fn [block]
      (final_blocks .append block)
    ))
    ((build_anthropic_user_blocks user_text image_attachments) .each (fn [block]
      (final_blocks .append block)
    ))
    (if final_blocks/.not_empty?
      (messages .append {^role "user" ^content final_blocks})
    )
  else
    (var final_blocks (build_anthropic_user_blocks user_text image_attachments))
    (if final_blocks/.not_empty?
      (messages .append {^role "user" ^content final_blocks})
    )
  )

  messages
)

(fn $ns/build_anthropic_request [history user_text tools_spec image_attachments = []]
  (var tools [])
  (tools_spec .each (fn [tool_spec]
    (tools .append (anthropic_tool_from_openai tool_spec))
  ))

  (var request {
    ^system get_system_prompt/.call
    ^messages (build_anthropic_messages history user_text image_attachments)
    ^tools tools
  })
  (log_anthropic_request request history)
  request
)

(fn $ns/normalize_openai_response [response]
  (var choices (try (response .get "choices" []) catch * []))
  (var response_output_text ((try (response .get "output_text" "") catch * "") .to_s))
  (if choices/.not_empty?
    (var first_choice choices/0)
    (var msg first_choice/message)
    (var content msg/content/.to_s)
    (var tool_calls (msg .get "tool_calls" []))
    (if_not tool_calls (tool_calls = []))
    (return {^content content ^tool_calls tool_calls})
  )

  (var output (ensure_array (try (response .get "output" []) catch * [])))
  (if output/.not_empty?
    (var text_parts [])
    (var tool_calls [])
    (output .each (fn [item]
      (var item_type (item/type || ""))
      (if (item_type == "message")
        (var item_content (item/content || []))
        (if (item_content is String)
          (if item_content/.not_empty?
            (text_parts .append item_content)
          )
        else
          ((ensure_array item_content) .each (fn [part]
            (if (((part/type || "") == "output_text") || ((part/type || "") == "text") || ((part/type || "") == "input_text"))
              (if part/text
                (text_parts .append part/text/.to_s)
              )
            )
          ))
        )
      elif (((item_type == "output_text") || (item_type == "text") || (item_type == "input_text")) && item/text)
        (text_parts .append item/text/.to_s)
      elif (item_type == "function_call")
        (tool_calls .append {
          ^id (item/call_id || item/id || "")
          ^type "function"
          ^function {
            ^name (item/name || "")
            ^arguments (item/arguments || "{}")
          }
        })
      )
    ))
    (var content (text_parts .join "\n\n"))
    (if (content/.empty? && response_output_text/.not_empty?)
      (content = response_output_text)
    )
    (if (content/.empty? && (tool_calls/.size == 0))
      (content = "I could not generate a response.")
    )
    (return {^content content ^tool_calls tool_calls})
  )

  (if response_output_text/.not_empty?
    (return {^content response_output_text ^tool_calls []})
  )

  {^content "I could not generate a response." ^tool_calls []}
)

(fn $ns/normalize_anthropic_response [response]
  (var blocks (ensure_array (try (response .get "content" []) catch * [])))
  (var text_parts [])
  (var tool_calls [])

  (blocks .each (fn [block]
    (var block_type (block/type || ""))
    (if (block_type == "text")
      (if block/text
        (text_parts .append block/text/.to_s)
      )
    elif (block_type == "tool_use")
      (var input_map (ensure_map (block/input || {})))
      (log .debug #"Anthropic tool_use id=#{(block/id || "")} name=#{(block/name || "")} input=#{input_map/.to_json}")
      (tool_calls .append {
        ^id (block/id || "")
        ^type "function"
        ^function {
          ^name (block/name || "")
          ^arguments input_map/.to_json
        }
      })
    )
  ))

  {^content (text_parts .join "\n\n") ^tool_calls tool_calls}
)

(fn provider_has_credentials []
  (if (CONFIG/llm/provider == "anthropic")
    (CONFIG/llm/anthropic/api_key/.not_empty? || CONFIG/llm/anthropic/auth_token/.not_empty?)
  elif (CONFIG/llm/provider == "openai")
    (CONFIG/llm/openai/api_key/.not_empty? || CONFIG/llm/openai/auth_token/.not_empty?)
  else
    false
  )
)

(fn openai_oauth_mode? []
  CONFIG/llm/openai/auth_token/.not_empty?
)

(fn mock_mode_response []
  (if (CONFIG/llm/provider == "anthropic")
    (return {^content "I received your message. (Running in mock mode - set CONFIG/llm/anthropic/api_key or CONFIG/llm/anthropic/auth_token to enable LLM)" ^tool_calls []})
  elif (CONFIG/llm/provider == "openai")
    (return {^content "I received your message. (Running in mock mode - set CONFIG/llm/openai/api_key or CONFIG/llm/openai/auth_token to enable LLM)" ^tool_calls []})
  )
  {^content #"Unsupported LLM provider: #{CONFIG/llm/provider}" ^tool_calls []}
)

(fn response_error_body_text [response]
  (try
    (if_not (response is Map)
      (return "")
    )
    (var raw_body ((response .get "raw_body" "") .to_s))
    (if raw_body/.not_empty?
      (return raw_body)
    )
    (var metadata ((response .get "metadata" nil) || nil))
    (if metadata
      (return metadata/.to_json)
    )
    ""
  catch *
    ""
  )
)

(fn $ns/error_message_from_response [response]
  (try
    (if_not (response is Map)
      (return "")
    )

    (var response_type ((response .get "type" "") .to_s))
    (var status_value_text ((response .get "status" "") .to_s))
    (var error_value ((response .get "error" nil) || nil))
    (var message "")
    (var has_error false)

    (if (error_value is Map)
      (has_error = true)
      (message = ((error_value .get "message" "") .to_s))
    )

    (if (message/.empty? && ((response_type == "error") || (response_type == "failed")))
      (message = ((response .get "message" "") .to_s))
    )

    (var status_code 0)
    (var status_text "")
    (try
      (var status_value ((response .get "status" nil) || nil))
      (if (status_value && ((status_value .to_i) > 0))
        (status_code = (status_value .to_i))
        (status_text = (status_value .to_s))
      )
    catch *
      nil
    )

    (if ((response_type == "error") || (response_type == "failed"))
      (has_error = true)
    )

    (if (status_code >= 400)
      (has_error = true)
    )

    (if (["failed" "incomplete" "cancelled" "expired"] .contains status_value_text)
      (has_error = true)
      (if message/.empty?
        (message = #"OpenAI response status=#{status_value_text}")
      )
      (if status_text/.empty?
        (status_text = status_value_text)
      )
    )

    (if_not has_error
      (return "")
    )

    (var body_text (response_error_body_text response))
    (var parts [])
    (if message/.not_empty?
      (parts .append message)
    )
    (if status_text/.not_empty?
      (parts .append #"status=#{status_text}")
    )
    (if body_text/.not_empty?
      (parts .append #"body=#{body_text}")
    )
    (parts .join " | ")
  catch *
    ""
  )
)

(fn call_openai [history user_text tools_spec image_attachments]
  (var oauth_mode (openai_oauth_mode?))
  (var request (if oauth_mode
    (build_openai_codex_request history user_text tools_spec image_attachments)
  else
    (build_openai_request history user_text tools_spec image_attachments)
  ))
  (var request_item_count (if oauth_mode request/input/.size else request/messages/.size))
  (log .info #"Calling LLM provider=openai mode=#{(if oauth_mode "codex-oauth" else "api-key")} model=#{CONFIG/llm/openai/model} items=#{request_item_count} tools=#{request/tools/.size} timeout_ms=#{CONFIG/llm/openai/timeout_ms}")
  (var client_opts {^model CONFIG/llm/openai/model ^timeout_ms CONFIG/llm/openai/timeout_ms})
  (if CONFIG/llm/openai/api_key/.not_empty?
    (client_opts .set "api_key" CONFIG/llm/openai/api_key)
  )
  (if CONFIG/llm/openai/auth_token/.not_empty?
    (client_opts .set "auth_token" CONFIG/llm/openai/auth_token)
  )
  (if CONFIG/llm/openai/account_id/.not_empty?
    (client_opts .set "account_id" CONFIG/llm/openai/account_id)
  )
  (if CONFIG/llm/openai/base_url/.not_empty?
    (client_opts .set "base_url" CONFIG/llm/openai/base_url)
  )
  (var client (new OpenAIClient client_opts))
  (var response (client .chat request))
  {^response response ^normalized (normalize_openai_response response)}
)

(fn call_anthropic [history user_text tools_spec image_attachments]
  (var request (build_anthropic_request history user_text tools_spec image_attachments))
  (log .info #"Calling LLM provider=anthropic model=#{CONFIG/llm/anthropic/model} messages=#{request/messages/.size} tools=#{request/tools/.size} timeout_ms=#{CONFIG/llm/anthropic/timeout_ms}")
  (var client_opts {^model CONFIG/llm/anthropic/model ^timeout_ms CONFIG/llm/anthropic/timeout_ms})
  (if CONFIG/llm/anthropic/api_key/.not_empty?
    (client_opts .set "api_key" CONFIG/llm/anthropic/api_key)
  )
  (if CONFIG/llm/anthropic/auth_token/.not_empty?
    (client_opts .set "auth_token" CONFIG/llm/anthropic/auth_token)
  )
  (if CONFIG/llm/anthropic/base_url/.not_empty?
    (client_opts .set "base_url" CONFIG/llm/anthropic/base_url)
  )
  (var client (new AnthropicClient client_opts))
  (var response (client .chat request))
  {^response response ^normalized (normalize_anthropic_response response)}
)

(fn $ns/call_llm [history user_text tools_spec image_attachments = []]
  (var images (ensure_array image_attachments))
  (var image_error (image_attachment_error images))
  (if image_error/.not_empty?
    (log .warn #"Image input rejected: #{image_error}")
    (return {^content image_error ^tool_calls []})
  )

  (if_not (provider_has_credentials)
    (if (images/.size > 0)
      (log .warn #"LLM image call rejected in mock mode (provider=#{CONFIG/llm/provider})")
      (return {^content #"Image inputs require configured #{(if (CONFIG/llm/provider == "anthropic") "Anthropic" elif (CONFIG/llm/provider == "openai") "OpenAI" else "LLM")} credentials." ^tool_calls []})
    )
    (log .info #"LLM call skipped (mock mode - provider=#{CONFIG/llm/provider})")
    (return (mock_mode_response))
  )

  (if genex/ai
    (try
      (var start_ms gene/now/.call/.to_i)
      (var call_result (if (CONFIG/llm/provider == "anthropic")
        (call_anthropic history user_text tools_spec images)
      else
        (call_openai history user_text tools_spec images)
      ))
      (log .debug "LLM chat returned")
      (var duration (gene/now/.call/.to_i - start_ms))
      (var response call_result/response)
      (log .debug "LLM post-call: checking response for error envelope")
      (if ((response is OpenAIError) || (response is AnthropicError))
        (var direct_error ((response .to_s) .to_s))
        (log .debug #"LLM post-call: direct error object detected len=#{direct_error/.size}")
        (log .error #"LLM call failed: #{direct_error}")
        (return {^content #"LLM error: #{direct_error}" ^tool_calls []})
      )
      (var error_message "")
      (if (response is Map)
        (var response_type ((response .get "type" "") .to_s))
        (var response_status ((response .get "status" "") .to_s))
        (if ((response_type == "error") || (response_type == "failed") || (["failed" "incomplete" "cancelled" "expired"] .contains response_status))
          (error_message = (error_message_from_response response))
        )
      )
      (log .debug #"LLM post-call: error envelope checked len=#{error_message/.size}")
      (if error_message/.not_empty?
        (log .error #"LLM call failed: #{error_message}")
        (return {^content #"LLM error: #{error_message}" ^tool_calls []})
      )
      (var normalized call_result/normalized)
      (log .debug "LLM post-call: normalized response ready")
      (log .info #"LLM responded in #{duration}ms provider=#{CONFIG/llm/provider} content_len=#{normalized/content/.size} tool_calls=#{normalized/tool_calls/.size}")
      (log .trace #"LLM response: #{normalized/content}")
      normalized
    catch *
      (log .error #"LLM call failed: #{$ex/message}")
      {^content #"LLM error: #{$ex/message}" ^tool_calls []}
    )
  else
    (log .error "genex/ai module unavailable")
    {^content "genex/ai module unavailable." ^tool_calls []}
  )
)
