# GeneClaw Tool Registry
# Registry/orchestration; individual tools live in src/tools/*.gene

(import CONFIG TMP_PATH DOCUMENT_ROOT ARTIFACT_ROOT from "config")
(import audit_log from "db")

(import register_get_time_tool from "tools/get_time")
(import register_shell_tool from "tools/shell")
(import register_read_file_tool from "tools/read_file")
(import register_write_file_tool from "tools/write_file")
(import register_http_get_tool from "tools/http_get")
(import register_browser_playwright_tool from "tools/browser_playwright")
(import register_schedule_tool from "tools/schedule")
(import register_self_upgrade_tool from "tools/self_upgrade")
(import register_web_search_tool from "tools/web_search")
(import register_list_files_tool from "tools/list_files")
(import register_edit_file_tool from "tools/edit_file")
(import register_patch_file_tool from "tools/patch_file")
(import register_send_message_tool from "tools/send_message")
(import register_send_document_tool from "tools/send_document")
(import register_delete_file_tool from "tools/delete_file")
(import register_tmux_send_tool from "tools/tmux_send")
(import register_tmux_tail_tool from "tools/tmux_tail")
(import register_grep_tool from "tools/grep")

(var log (new genex/logging/Logger $ns))

# Tool registry: name -> {^description ^params ^handler}
(var TOOLS {})

(fn tool_result_success? [result]
  (if (result is Map)
    (result/ok || result/error/.empty?)
  else
    true
  )
)

(fn tool_result_error [result fallback = "Tool returned an error"]
  (result/error || fallback)
)

(fn $ns/register_tool [name description params handler]
  (TOOLS .set name {
    ^description description
    ^params params
    ^handler handler
  })
  (log .debug #"Registered tool: #{name}")
)

(fn $ns/invoke_tool [run_id workspace_id user_id channel_id thread_id session_id tool_name args]
  (log .info #"invoke_tool run=#{run_id} tool=#{tool_name}")
  (var tool_args (ifel (args is Map) args {}))
  (if (args is Map)
    (log .debug #"invoke_tool args=#{tool_args/.to_json}")
  else
    (log .warn "invoke_tool args is not a map; coercing to {}")
  )

  # Inject invocation context so tools like 'schedule' can access it
  (tool_args .set "_context" {
    ^run_id run_id
    ^workspace_id workspace_id
    ^user_id user_id
    ^channel_id channel_id
    ^thread_id thread_id
    ^thread_ts thread_id
    ^session_id session_id
  })

  (var tool TOOLS/<tool_name>)
  (if_not tool
    (log .warn #"Unknown tool requested: #{tool_name}")
    (audit_log run_id workspace_id tool_name "not_found" tool_args nil 0)
    (return {^ok false ^error #"Unknown tool: #{tool_name}"})
  )

  (var start_ms gene/now/.call/.to_i)
  (try
    (var missing_args [])
    (var required_args (if (((tool/params is Map) && (tool/params/required is Array)))
      tool/params/required
    else
      []
    ))
    (for required_name in required_args
      (var key ((required_name || "") .to_s))
      (if key/.not_empty?
        (if ((tool_args .get key nil) == nil)
          (missing_args .append key)
        )
      )
    )
    (if missing_args/.not_empty?
      (var error_msg #"Missing required arguments for #{tool_name}: #{(missing_args .join ", ")}")
      (var result {^error error_msg ^missing missing_args})
      (log .warn #"Tool #{tool_name} rejected before execution: #{error_msg}")
      (audit_log run_id workspace_id tool_name "failed" tool_args result 0)
      (return {^ok false ^error error_msg ^result result})
    )

    (var result (tool/handler tool_args))
    (var duration (gene/now/.call/.to_i - start_ms))
    (if (tool_result_success? result)
      (log .info #"Tool #{tool_name} succeeded in #{duration}ms")
      (log .debug #"Tool #{tool_name} result=#{result/.to_json}")
      (audit_log run_id workspace_id tool_name "success" tool_args result duration)
      {^ok true ^result result}
    else
      (var error_msg (tool_result_error result))
      (log .warn #"Tool #{tool_name} returned failure in #{duration}ms: #{error_msg}")
      (log .debug #"Tool #{tool_name} result=#{result/.to_json}")
      (audit_log run_id workspace_id tool_name "failed" tool_args result duration)
      {^ok false ^error error_msg ^result result}
    )
  catch *
    (var duration (gene/now/.call/.to_i - start_ms))
    (log .error #"Tool #{tool_name} failed after #{duration}ms: #{$ex/message}")
    (audit_log run_id workspace_id tool_name "failed" tool_args {^error $ex/message} duration)
    {^ok false ^error #"Tool failed: #{$ex/message}"}
  )
)

# Build OpenAI-format tools array for native tool calling
(fn $ns/build_tools_spec []
  (var specs [])
  (TOOLS .each (fn [name def]
    (specs .append {
      ^type "function"
      ^function {
        ^name name
        ^description def/description
        ^parameters def/params
      }
    })
  ))
  specs
)

(fn $ns/init_tools []
  (log .info "Initializing built-in tools")

  # Ensure scratch and asset roots exist
  (try
    (system/shell #"mkdir -p '#{TMP_PATH}' '#{DOCUMENT_ROOT}' '#{ARTIFACT_ROOT}'")
    (log .debug #"Managed roots ready: #{TMP_PATH}, #{DOCUMENT_ROOT}, #{ARTIFACT_ROOT}")
  catch *
    (log .warn #"Could not create managed roots: #{$ex/message}")
  )

  # Register tool modules
  (register_get_time_tool register_tool log)
  (register_shell_tool register_tool log TMP_PATH)
  (register_read_file_tool register_tool log TMP_PATH)
  (register_write_file_tool register_tool log TMP_PATH)
  (register_http_get_tool register_tool log)
  (register_browser_playwright_tool register_tool log TMP_PATH ARTIFACT_ROOT)
  (register_schedule_tool register_tool log)
  (register_self_upgrade_tool register_tool log)
  (register_web_search_tool register_tool log)
  (register_list_files_tool register_tool log TMP_PATH)
  (register_edit_file_tool register_tool log TMP_PATH)
  (register_patch_file_tool register_tool log TMP_PATH)
  (register_send_message_tool register_tool log)
  (register_send_document_tool register_tool log)
  (register_delete_file_tool register_tool log TMP_PATH)
  (register_tmux_send_tool register_tool log)
  (register_tmux_tail_tool register_tool log)
  (register_grep_tool register_tool log TMP_PATH)

  (log .info #"Registered #{TOOLS/.size} tools")
)
