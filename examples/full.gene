# =============================================================================
# 19. TYPE CHECKING
# =============================================================================

# Runtime type check
(println (typeof 42))         # => Int
(println (typeof "hi"))       # => String
(println (typeof true))       # => Bool

# Instance check
(println (p is Point))        # => true
(println (d is Animal))       # => true (via inheritance)
(println (d is Dog))          # => true

# Type annotations (gradual typing — optional, checked at runtime)
(fn divide [a: Int b: Int] -> Float
  (a / b))

# Calling with wrong type raises runtime error
# (divide "x" 1)             # => Error: type mismatch

