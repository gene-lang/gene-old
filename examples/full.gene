# =============================================================================
# 28. COMPLEX EXAMPLES
# =============================================================================

# --- Data processing pipeline ---
(var users [
  {^name "Alice" ^age 30 ^role "admin"}
  {^name "Bob" ^age 25 ^role "user"}
  {^name "Carol" ^age 35 ^role "admin"}])

(for user in users
  (if (user/role == "admin")
    (println user/name "is an admin, age:" user/age)))

# --- Class with full features ---
(class API
  (ctor [base_url]
    (/url = base_url)
    (/cache = {}))

  (method request [endpoint]
    (var cached /cache/endpoint)
    (if cached
      cached
    else
      (var result (/url .append endpoint))
      (/cache/endpoint = result)
      result))

  (method clear_cache []
    (/cache = {})))

(var api (new API "https://api.example.com"))
(println (api .request "/users"))

# --- Recursive data structure ---
(fn tree_sum [node]
  (if (node == nil)
    0
  else
    (+ node/value
       (tree_sum node/left)
       (tree_sum node/right))))

# --- Calculator with memory ---
(class Calculator
  (ctor []
    (/memory = {})
    (/history = []))

  (method compute [op a b]
    (var result
      (if (op == "add") (a + b)
       elif (op == "sub") (a - b)
       elif (op == "mul") (a * b)
       elif (op == "div") (a / b)
       else (throw "Unknown op")))
    (/history .push {^op op ^a a ^b b ^result result})
    result)

  (method store [key value]
    (/memory/key = value))

  (method recall [key]
    /memory/key))

(var calc (new Calculator))
(println (calc .compute "add" 5 3))  # => 8

# =============================================================================
# 29. SPECIAL VARIABLES
# =============================================================================

# $app      — the application object
# $ex       — current exception in catch block
# $caller_eval — evaluate expression in caller's context (in macros)
# $env      — environment variables map
# $program  — current program path
# $cmd_args — command line arguments
# /         — self reference inside methods
# /prop     — self/prop inside methods

(println "=== Gene Complete Feature Reference ===")

# =============================================================================
# 30. MISCALLANEOUS
# =============================================================================

# This is handled by the parser
(a; b)          # = ((a) b)
(a; b; c)       # = (((a) b) c)
(a ^x 1; b ^y 2; c)       # = (((a ^x 1) b ^y 2) c)
